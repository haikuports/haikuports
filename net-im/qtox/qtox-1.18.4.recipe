SUMMARY="A chat, voice, video, and file transfer IM client"
DESCRIPTION="qTox is a powerful Tox client that follows the Tox design \
guidelines while running on all major platforms."
HOMEPAGE="https://github.com/qTox/qTox"
COPYRIGHT="2015-2021 qTox maintainers"
LICENSE="GNU GPL v3"
REVISION="1"
SOURCE_URI="https://github.com/TokTok/qTox/releases/download/v$portVersion/v$portVersion.tar.xz"
CHECKSUM_SHA256="0fe87ad88f01ae7cb1b8af6adb686e1be3ed69fe0372ea24b87a1ac30267b7ac"
SOURCE_FILENAME="qtox-v$portVersion.tar.xz"
SOURCE_DIR="qTox-v$portVersion"
ADDITIONAL_FILES="qtox.rdef.in"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	qtox$secondaryArchSuffix = $portVersion
	app:qTox = $portVersion
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libavcodec$secondaryArchSuffix
	lib:libavdevice$secondaryArchSuffix
	lib:libavformat$secondaryArchSuffix
	lib:libavutil$secondaryArchSuffix
	lib:libexif$secondaryArchSuffix
	lib:libGL$secondaryArchSuffix
	lib:libKF6SonnetCore$secondaryArchSuffix
	lib:libopenal$secondaryArchSuffix
	lib:libopus$secondaryArchSuffix
	lib:libqrencode$secondaryArchSuffix
	lib:libQt6Core$secondaryArchSuffix
	lib:libQt6DBus$secondaryArchSuffix
	lib:libQt6Gui$secondaryArchSuffix
	lib:libQt6Network$secondaryArchSuffix
	lib:libQt6Svg$secondaryArchSuffix
	lib:libQt6Widgets$secondaryArchSuffix
	lib:libQt6Xml$secondaryArchSuffix
	lib:libsodium$secondaryArchSuffix
	lib:libsqlcipher$secondaryArchSuffix
	lib:libswscale$secondaryArchSuffix
	lib:libtoxcore$secondaryArchSuffix
	lib:libvpx$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	qt6_tools${secondaryArchSuffix}_devel
	devel:libavcodec$secondaryArchSuffix
	devel:libavdevice$secondaryArchSuffix
	devel:libavformat$secondaryArchSuffix
	devel:libavutil$secondaryArchSuffix
	devel:libexif$secondaryArchSuffix
	devel:libGL$secondaryArchSuffix
	devel:libKF6SonnetCore$secondaryArchSuffix
	devel:libopenal$secondaryArchSuffix
	devel:libopus$secondaryArchSuffix
	devel:libqrencode$secondaryArchSuffix
	devel:libQt6Core$secondaryArchSuffix
	devel:libQt6Svg$secondaryArchSuffix
	devel:libsodium$secondaryArchSuffix
	devel:libsqlcipher$secondaryArchSuffix
	devel:libswscale$secondaryArchSuffix
	devel:libtoxcore$secondaryArchSuffix
	devel:libvpx$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:cmake
	cmd:gcc$secondaryArchSuffix
	cmd:make
	cmd:pkg_config$secondaryArchSuffix
	"

BUILD()
{
	cmake -B build -S . -DCMAKE_BUILD_TYPE=Release \
		$cmakeDirArgs \
		-DCMAKE_INSTALL_BINDIR=$appsDir \
		-DGIT_DESCRIBE:STRING=${portVersion}_$REVISION \
		-DGIT_DESCRIBE_EXACT=RELEASE \
		-DUPDATE_CHECK=OFF \
		-DCMAKE_EXE_LINKER_FLAGS=-lnetwork \
		-Wno-dev

	make -C build $jobArgs
}

INSTALL()
{
	make -C build install
	mv $appsDir/qtox $appsDir/qTox

	# we are not linux
	rm -rf $dataDir/{applications,metainfo} $prefix/share

	local APP_SIGNATURE="application/x-vnd.qtox"
	local MAJOR="`echo "$portVersion" | cut -d. -f1`"
	local MIDDLE="`echo "$portVersion" | cut -d. -f2`"
	local MINOR="`echo "$portVersion" | cut -d. -f3`"
	local LONG_INFO="$SUMMARY"
	sed \
		-e "s|@APP_SIGNATURE@|$APP_SIGNATURE|" \
		-e "s|@MAJOR@|$MAJOR|" \
		-e "s|@MIDDLE@|$MIDDLE|" \
		-e "s|@MINOR@|$MINOR|" \
		-e "s|@LONG_INFO@|$LONG_INFO|" \
		$portDir/additional-files/qtox.rdef.in > qtox.rdef

	addResourcesToBinaries qtox.rdef $appsDir/qTox
	addAppDeskbarSymlink $appsDir/qTox
}

TEST()
{
	# 97% tests passed, 1 tests failed out of 35
	ctest --test-dir build --output-on-failure
}
