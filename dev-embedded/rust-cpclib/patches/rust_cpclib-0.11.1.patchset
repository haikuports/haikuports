From 85c80e3f948dd7c0c9f8df6d683e6f58651315e8 Mon Sep 17 00:00:00 2001
From: PulkoMandy <pulkomandy@pulkomandy.tk>
Date: Thu, 14 May 2026 21:32:07 +0200
Subject: More reasonable stack size

1GB of stack is certainly not needed, and not allowed on Haiku anyways.

diff --git a/cpclib-basm/src/main.rs b/cpclib-basm/src/main.rs
index 384c12c..7a2d631 100644
--- a/cpclib-basm/src/main.rs
+++ b/cpclib-basm/src/main.rs
@@ -74,7 +74,7 @@ fn main() {
     use std::process::exit;
 
     let code = std::thread::Builder::new()
-        .stack_size(1024 * 1024 * 1024)
+        .stack_size(1024 * 1024)
         .spawn(basm)
         .unwrap()
         .join()
-- 
2.52.0


From 02065bc7ad03530c737ce0acf9eeb27c2c6df0eb Mon Sep 17 00:00:00 2001
From: PulkoMandy <pulkomandy@pulkomandy.tk>
Date: Fri, 15 May 2026 16:04:08 +0200
Subject: Make things build on Haiku

- Remove use of cfg_select (not available yet in Rust 1.94.1)
- Define some URLs and archive types for Haiku (just so things can be
  built, the URLs may not exist or be for the wrong platform)

diff --git a/cpclib-bndbuild/src/env.rs b/cpclib-bndbuild/src/env.rs
index 3e92671..1cebe65 100644
--- a/cpclib-bndbuild/src/env.rs
+++ b/cpclib-bndbuild/src/env.rs
@@ -23,7 +23,7 @@ pub fn create_template_env<P: AsRef<Utf8Path>, S1: AsRef<str>, S2: AsRef<str>>(
         }
     }
 
-    #[cfg(any(target_os = "linux", target_os = "macos"))]
+    #[cfg(any(target_os = "linux", target_os = "macos", target_os = "haiku"))]
     fn basm_escape_path(path: String) -> Result<String, Error> {
         Ok(path)
     }
diff --git a/cpclib-crunchers/build.rs b/cpclib-crunchers/build.rs
index a964615..7210381 100644
--- a/cpclib-crunchers/build.rs
+++ b/cpclib-crunchers/build.rs
@@ -56,7 +56,7 @@ fn build_others() {
 fn build_shrinkler() {
     cxx_build::bridge("src/shrinkler.rs")
         .file("extra/Shrinkler4.6NoParityContext//basm_bridge.cpp")
-        .flag_if_supported("-std=c++14")
+        .std("c++14")
         .compile("cpclib-crunchers");
 
     println!("cargo:rerun-if-changed=src/shrinkler.rs");
diff --git a/cpclib-runner/src/delegated.rs b/cpclib-runner/src/delegated.rs
index 45289b4..3cde67e 100644
--- a/cpclib-runner/src/delegated.rs
+++ b/cpclib-runner/src/delegated.rs
@@ -62,7 +62,8 @@ pub fn github_get_assets_for_version_url<GI: GithubInformation>(
 pub struct MutiplatformUrls {
     pub linux: Option<String>,
     pub windows: Option<String>,
-    pub macos: Option<String>
+    pub macos: Option<String>,
+    pub haiku: Option<String>
 }
 
 impl MutiplatformUrls {
@@ -71,6 +72,7 @@ impl MutiplatformUrls {
             .linux(url)
             .windows(url)
             .macos(url)
+            .haiku(url)
             .build()
     }
 
@@ -81,6 +83,8 @@ impl MutiplatformUrls {
         return self.macos.as_ref();
         #[cfg(target_os = "linux")]
         return self.linux.as_ref();
+        #[cfg(target_os = "haiku")]
+        return self.haiku.as_ref();
     }
 }
 
diff --git a/cpclib-runner/src/runner/assembler/rasm.rs b/cpclib-runner/src/runner/assembler/rasm.rs
