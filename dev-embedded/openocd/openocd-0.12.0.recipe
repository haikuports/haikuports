SUMMARY="Open On-Chip Debugger"
DESCRIPTION="The Open On-Chip Debugger (OpenOCD) aims to provide debugging, in-system programming \
and boundary-scan testing for embedded target devices.

It does so with the assistance of a debug adapter, which is a small hardware module which helps \
provide the right kind of electrical signaling to the target being debugged.

OpenOCD currently supports many types of hardware dongles: USB-based, parallel port-based, and \
other standalone boxes that run OpenOCD internally.

It allows ARM7 (ARM7TDMI and ARM720t), ARM9 (ARM920T, ARM922T, ARM926EJ–S, ARM966E–S), XScale \
(PXA25x, IXP42x), Cortex-M3 (Stellaris LM3, STMicroelectronics STM32 and Energy Micro EFM32) and \
Intel Quark (x10xx) based cores to be debugged via the GDB protocol.

Flash writing is supported for external CFI-compatible NOR flashes (Intel and AMD/Spansion \
command set) and several internal flashes (LPC1700, LPC1800, LPC2000, LPC4300, AT91SAM7, \
AT91SAM3U, STR7x, STR9x, LM3, STM32x and EFM32). Preliminary support for various NAND flash \
controllers (LPC3180, Orion, S3C24xx, more) is included."
HOMEPAGE="https://homepage/of/projectx.org"
COPYRIGHT="2008-2022 The OpenOCD Project
2007-2008 Spencer Oliver
2008-2010 Oyvind Harboe
2008 Duane Ellis
2009-2010 David Brownell"
LICENSE="GNU GPL v2"
SOURCE_URI="https://sourceforge.net/projects/openocd/files/openocd/$portVersion/openocd-$portVersion.tar.bz2"
SOURCE_DIR="$portVersionedName"
CHECKSUM_SHA256="af254788be98861f2bd9103fe6e60a774ec96a8c374744eef9197f6043075afa"
PATCHES="openocd-$portVersion.patchset"
REVISION="1"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	openocd$secondaryArchSuffix = $portVersion
	cmd:openocd$secondaryArchSuffix
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libftdi1$secondaryArchSuffix
	lib:libusb_1.0$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libftdi1$secondaryArchSuffix
	devel:libusb_1.0$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:awk
	cmd:cmp
	cmd:diff
	cmd:gcc$secondaryArchSuffix
	cmd:make
	cmd:pkg_config$secondaryArchSuffix
	"

BUILD()
{
	export CFLAGS="-O2 -DB_USE_POSITIVE_POSIX_ERRORS"
	export LDFLAGS="-lnetwork -lposix_error_mapper"
	runConfigure ./configure
	make $jobArgs
}

INSTALL()
{
	make install
}
