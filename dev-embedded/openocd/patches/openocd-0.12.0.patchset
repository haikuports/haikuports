From 89659d3ef075b45df05ff3e563d79a7bfa5808b1 Mon Sep 17 00:00:00 2001
From: PulkoMandy <pulkomandy@pulkomandy.tk>
Date: Tue, 19 May 2026 11:25:06 +0200
Subject: Haiku compatibility fixes

- Missing include of sys/select.h
- Errors in Haiku are larger than 255, but GCC documentation says the
  error code for the E command is a two character value that is not well
  defined. Our entire 32 bit error code won't fit so just send some bits

diff --git a/src/jtag/drivers/libjaylink/libjaylink/socket.c b/src/jtag/drivers/libjaylink/libjaylink/socket.c
index 6a9fdd7..be48e06 100644
--- a/src/jtag/drivers/libjaylink/libjaylink/socket.c
+++ b/src/jtag/drivers/libjaylink/libjaylink/socket.c
@@ -22,6 +22,7 @@
 #include <winsock2.h>
 #else
 #include <sys/types.h>
+#include <sys/select.h>
 #include <sys/socket.h>
 #include <unistd.h>
 #include <fcntl.h>
diff --git a/src/server/gdb_server.c b/src/server/gdb_server.c
index d8dbc2c..6fee3cf 100644
--- a/src/server/gdb_server.c
+++ b/src/server/gdb_server.c
@@ -1136,10 +1136,10 @@ static int gdb_connection_closed(struct connection *connection)
 	return ERROR_OK;
 }
 
-static void gdb_send_error(struct connection *connection, uint8_t the_error)
+static void gdb_send_error(struct connection *connection, uint32_t the_error)
 {
 	char err[4];
-	snprintf(err, 4, "E%2.2X", the_error);
+	snprintf(err, 4, "E%2.2X", the_error & 0xFF);
 	gdb_put_packet(connection, err, 3);
 }
 
-- 
2.52.0

