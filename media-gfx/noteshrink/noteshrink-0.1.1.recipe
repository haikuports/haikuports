SUMMARY="Convert scans of handwritten notes to beautiful, compact PDFs"
DESCRIPTION="Noteshrink is an utility that is used to convert scans of notes to compact PDFs."
HOMEPAGE="https://github.com/mzucker/noteshrink"
COPYRIGHT="2016 Matt Zucker"
LICENSE="MIT"
REVISION="2"
SOURCE_URI="https://github.com/mzucker/noteshrink/archive/$portVersion.tar.gz"
CHECKSUM_SHA256="2a29c09768973e688b693b61337c6c49384e8123cf88824dba335cc8c4ed2ca8"

ARCHITECTURES="any"
# The package is "any" because the result is only a Python script under /bin/.
# However, on gcc2 systems, it will depend on Python modules only available for _x86.
if [ "$targetArchitecture" = x86_gcc2 ]; then
	hostArchSuffix="_x86"
else
	hostArchSuffix=""
fi

PROVIDES="
	noteshrink = $portVersion
	cmd:noteshrink
	"
REQUIRES="
	numpy_python39
	pillow${hostArchSuffix}_python39
	scipy${hostArchSuffix}_python39
	cmd:convert
	# These are optional (used for post-processing: -C -O and -Q options)
	# cmd:pngcrush
	# cmd:pngquant
	# cmd:optipng
	"

TEST_REQUIRES="
	numpy_python39
	pillow${hostArchSuffix}_python39
	scipy${hostArchSuffix}_python39
	cmd:convert
	cmd:make
	cmd:optipng
	"

INSTALL()
{
	mkdir -p $binDir
	sed -i 's|#!/usr/bin/env python|#!/bin/python3|' noteshrink.py
	cp noteshrink.py $binDir/noteshrink
}


TEST()
{
	# As test, let it convert the examples:
	rm -f examples_output/*
	make
}
