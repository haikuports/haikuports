SUMMARY="An interactive post-processing tool for scanned pages"
DESCRIPTION="ScanTailor is an interactive post-processing tool for scanned pages. It performs \
operations such as:
* page splitting,
* deskewing,
* adding/removing borders,
* selecting content
* ... and others.
You give it raw scans, and you get pages ready to be printed or assembled into a PDF or DjVu \
file. Scanning, optical character recognition, and assembling multi-page documents are out of \
scope of this project."
HOMEPAGE="https://github.com/ScanTailor-Advanced/scantailor-advanced"
COPYRIGHT="2015-present Joseph Artsimovich and 4lex4"
LICENSE="GNU GPL v3"
REVISION="1"
SOURCE_URI="https://github.com/ScanTailor-Advanced/scantailor-advanced/archive/refs/tags/v$portVersion.tar.gz"
CHECKSUM_SHA256="02026900c5af268ffbc7e518dca55529d212bb971d6b0afd3a2e7a5cc6df26d4"
SOURCE_FILENAME="scantailor-advanced-v$portVersion.tar.gz"
SOURCE_DIR="scantailor-advanced-$portVersion"
ADDITIONAL_FILES="scantailor_advanced.rdef.in"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	scantailor_advanced$secondaryArchSuffix = $portVersion
	app:ScanTailor = $portVersion
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libGl$secondaryArchSuffix
	lib:libjpeg$secondaryArchSuffix
	lib:libpng16$secondaryArchSuffix
	lib:libQt6Core$secondaryArchSuffix
	lib:libQt6Gui$secondaryArchSuffix
	lib:libQt6Network$secondaryArchSuffix
	lib:libQt6Opengl$secondaryArchSuffix
	lib:libQt6OpenglWidgets$secondaryArchSuffix
	lib:libQt6Svg$secondaryArchSuffix
	lib:libQt6Widgets$secondaryArchSuffix
	lib:libQt6Xml$secondaryArchSuffix
	lib:libtiff$secondaryArchSuffix
	lib:libz$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	qt6_tools${secondaryArchSuffix}_devel
	devel:libboost_unit_test_framework$secondaryArchSuffix >= 1.91.0
	devel:libpng16$secondaryArchSuffix
	devel:libjpeg$secondaryArchSuffix
	devel:libQt6Core$secondaryArchSuffix
	devel:libQt6Svg$secondaryArchSuffix
	devel:libtiff$secondaryArchSuffix
	devel:libz$secondaryArchSuffix
	"

BUILD_PREREQUIRES="
	cmd:cmake
	cmd:gcc$secondaryArchSuffix
	cmd:make
	"

BUILD()
{
	cmake -B build -S . -DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=$appsDir/ScanTailor \
		-DCMAKE_SKIP_RPATH=ON \
		-DBUILD_TESTS=OFF \
		-Wno-dev

	make -C build $jobArgs
}

INSTALL()
{
	make -C build install

	mv $appsDir/ScanTailor/bin/scantailor $appsDir/ScanTailor/ScanTailor
	mv $appsDir/ScanTailor/share/scantailor-advanced/translations/* $appsDir/ScanTailor

	rm -rf $appsDir/ScanTailor/{bin,share}

	local MAJOR="`echo "$portVersion" | cut -d. -f1`"
	local MIDDLE="`echo "$portVersion" | cut -d. -f2`"
	local MINOR="`echo "$portVersion" | cut -d. -f3`"
	local APP_NAME="ScanTailor"
	local LONG_INFO="$SUMMARY"
	local APP_SIGNATURE="application/x-vnd.scantailor"
	sed \
		-e "s|@MAJOR@|$MAJOR|" \
		-e "s|@MIDDLE@|$MIDDLE|" \
		-e "s|@MINOR@|$MINOR|" \
		-e "s|@APP_NAME@|$APP_NAME|" \
		-e "s|@LONG_INFO@|$LONG_INFO|" \
		-e "s|@APP_SIGNATURE@|$APP_SIGNATURE|" \
		$portDir/additional-files/scantailor_advanced.rdef.in > scantailor.rdef

	addResourcesToBinaries scantailor.rdef $appsDir/ScanTailor/ScanTailor
	mimeset -f $appsDir/ScanTailor/ScanTailor

	addAppDeskbarSymlink $appsDir/ScanTailor/ScanTailor
}

TEST()
{
	# 60% tests passed, 2 tests failed out of 5
	ctest --test-dir build --output-on-failure
}
