SUMMARY="Menu files for LXQt Panel, Configuration Center and PCManFM-Qt/libfm-qt"
DESCRIPTION="Freedesktop.org compliant menu files for LXQt Panel, Configuration Center \
and PCManFM-Qt/libfm-qt.

Runtime and build dependency for lxqt-panel, lxqt-config and pcmanfm-qt.

Replacement for and partially based on lxmenu-data (LXDE)."
HOMEPAGE="https://github.com/lxqt/lxqt-menu-data/"
COPYRIGHT="1991, 1999 Free Software Foundation, Inc."
LICENSE="GNU LGPL v2.1"
REVISION="1"
SOURCE_URI="https://github.com/lxqt/lxqt-menu-data/releases/download/$portVersion/lxqt-menu-data-$portVersion.tar.xz"
CHECKSUM_SHA256="87b4d372afcf61ec2272ceb5eedba873d8a8a73e5b239a55446b52950b72d596"
SOURCE_DIR="lxqt-menu-data-$portVersion"
PATCHES="lxqt_menu_data-$portVersion.patchset"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

GLOBAL_WRITABLE_FILES="
	settings/menus directory keep-old
	"

PROVIDES="
	lxqt_menu_data$secondaryArchSuffix = $portVersion
	"
REQUIRES="
	haiku$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	lxqt_build_tools$secondaryArchSuffix
	devel:libQt5Core$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:cmake
	cmd:gcc$secondaryArchSuffix
	cmd:linguist$secondaryArchSuffix >= 5
	cmd:make
	cmd:perl
	"

BUILD()
{
	cmake -B build -S . -DCMAKE_BUILD_TYPE=Release \
		$cmakeDirArgs

	make -C build $jobArgs
}

INSTALL()
{
	make -C build install
}

TEST()
{
	make check
}
