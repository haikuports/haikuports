SUMMARY="A NES emulator for Haiku"
DESCRIPTION="This is a NES emulator. \
By now, it can run ROMs from mappers NROM, UxROM and CNROM. \
Popular games available for this platform are Super Mario Bros, Castlevania, Contra or Mega-Man. \
No games are shared in this repository since it can violate the intellectual property rights. "
HOMEPAGE="https://github.com/javier2003mr/MontaNES"
COPYRIGHT="2026 J. M. Rubio"
LICENSE="MIT"
REVISION="1"
srcGitRev="75bc4aa9df9908457935115edc43918f7144e48c"
SOURCE_URI="https://github.com/javier2003mr/MontaNES/archive/$srcGitRev.tar.gz"
CHECKSUM_SHA256="b069bea7cb029a276a1d77d57d2aff8411426a194175c87690124c583372c335"
SOURCE_DIR="MontaNES-$srcGitRev"
ARCHITECTURES="x86_64"
PROVIDES="
	montanes = $portVersion
	app:montanes = $portVersion
	"
REQUIRES="
	haiku
	"
BUILD_REQUIRES="
	haiku_devel
	"
BUILD_PREREQUIRES="
	cmd:g++
	cmd:make
	cmd:xres
	"
BUILD()
{
	make
}
INSTALL()
{
	mkdir -p $appsDir
	ls
	cp -a bin/montaNES $appsDir
	addAppDeskbarSymlink $appsDir/montaNES
}
