SUMMARY="Accessibilty tools helper library, used e.g. by screen readers"
DESCRIPTION="This library is used when writing accessibility clients such as screen readers. It \
comes with some examples demonstrating the API. These small helpers may be useful when testing \
accessibility.

One of them writes all accessibiliy interfaces an application provides as text output. The other, \
more advanced application shows a tree of objects and allows some interaction and exploration."
HOMEPAGE="https://invent.kde.org/libraries/libqaccessibilityclient"
COPYRIGHT="2010-2023 KDE Organisation"
LICENSE="GNU LGPL v2.1"
REVISION="1"
SOURCE_URI="https://download.kde.org/Attic/libqaccessibilityclient/libqaccessibilityclient-$portVersion.tar.xz"
CHECKSUM_SHA256="4c50c448622dc9c5041ed10da7d87b3e4e71ccb49d4831a849211d423c5f5d33"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

# On x86_gcc2 we don't want to install the commands in bin/<arch>/, but in bin/.
commandBinDir=$binDir
commandSuffix=$secondaryArchSuffix
if [ "$targetArchitecture" = x86_gcc2 ]; then
	commandSuffix=
	commandBinDir=$prefix/bin
fi

libVersion="$portVersion"
libVersionCompat="$libVersion compat >= ${libVersion%%.*}"

PROVIDES="
	libqaccessibilityclient$secondaryArchSuffix = $portVersion
	cmd:dumper$commandSuffix = $portVersion
	lib:libqaccessibilityclient_qt6$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libGL$secondaryArchSuffix
	# Qt6
	lib:libQt6Core$secondaryArchSuffix
	lib:libQt6DBus$secondaryArchSuffix
	lib:libQt6Gui$secondaryArchSuffix
	lib:libQt6Widgets$secondaryArchSuffix
	"

PROVIDES_devel="
	libqaccessibilityclient${secondaryArchSuffix}_devel = $portVersion
	devel:libqaccessibilityclient_qt6$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES_devel="
	libqaccessibilityclient$secondaryArchSuffix == $portVersion base
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	# KF6
	extra_cmake_modules$secondaryArchSuffix
	# Qt6
	devel:libQt6Core$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:cmake
	cmd:g++$secondaryArchSuffix
	cmd:make
	cmd:pkg_config$secondaryArchSuffix
	"

TEST_REQUIRES="
	qt6_haikuplugins$secondaryArchSuffix
#	cmd:dbus_launch
	"

BUILD()
{
	cmake -B build -S . -DCMAKE_BUILD_TYPE=Release \
		$cmakeDirArgs \
		-DCMAKE_INSTALL_BINDIR=$commandBinDir \
		-DBUILD_WITH_QT6=ON \
		-DCMAKE_SKIP_RPATH=YES \
		-DBUILD_TESTING=OFF \
		-Wno-dev

	make -C build $jobArgs
}

INSTALL()
{
	make -C build install

	prepareInstalledDevelLib \
		libqaccessibilityclient-qt6

	packageEntries devel \
		$developDir \
		$libDir/cmake
}

TEST()
{
	# 0% tests passed, 1 tests failed out of 1
#	export $(dbus-launch)
	export LIBRARY_PATH="$sourceDir/build/bin${LIBRARY_PATH:+:$LIBRARY_PATH}"
	ctest --test-dir build --output-on-failure
}
