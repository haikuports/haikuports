SUMMARY="Tiny SVG rendering library in C"
DESCRIPTION="PlutoSVG is a compact and efficient SVG rendering library written in C. \
It is specifically designed for parsing and rendering SVG documents embedded in OpenType fonts, \
providing an optimal balance between speed and minimal memory usage. It is also suitable for \
rendering scalable icons."
HOMEPAGE="https://github.com/sammycage/plutosvg"
COPYRIGHT="2020-2026 Samuel Ugochukwu"
LICENSE="MIT"
REVISION="1"
SOURCE_URI="$HOMEPAGE/archive/refs/tags/v$portVersion.tar.gz"
CHECKSUM_SHA256="78561b571ac224030cdc450ca2986b4de915c2ba7616004a6d71a379bffd15f3"
SOURCE_FILENAME="plutosvg-$portVersion.tar.gz"
SOURCE_DIR="plutosvg-$portVersion"

ARCHITECTURES="all ?x86_gcc2"
SECONDARY_ARCHITECTURES="?x86"

libVersion="0"
libVersionCompat="$libVersion compat >= ${libVersion%%.*}"

PROVIDES="
	plutosvg$secondaryArchSuffix = $portVersion
	lib:libplutosvg$secondaryArchSuffix = $libVersionCompat
	lib:libplutovg$secondaryArchSuffix
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libfreetype$secondaryArchSuffix
	lib:libplutovg$secondaryArchSuffix
	"

PROVIDES_devel="
	plutosvg${secondaryArchSuffix}_devel = $portVersion
	devel:libplutosvg$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES_devel="
	plutosvg$secondaryArchSuffix == $portVersion base
	devel:libfreetype$secondaryArchSuffix
	devel:libplutovg$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libfreetype$secondaryArchSuffix
	devel:libplutovg$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:cmake
	cmd:gcc$secondaryArchSuffix
	cmd:ld$secondaryArchSuffix
	cmd:make
	cmd:pkg_config$secondaryArchSuffix
	"

defineDebugInfoPackage plutosvg$secondaryArchSuffix \
	$libDir/libplutosvg.so.$libVersion

BUILD()
{
	cmake -S. -Bbuild -DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DBUILD_SHARED_LIBS=ON \
		-DPLUTOSVG_ENABLE_FREETYPE=ON \
		-DCMAKE_INSTALL_PREFIX=$prefix \
		-DCMAKE_INSTALL_INCLUDEDIR=$includeDir \
		-DCMAKE_INSTALL_LIBDIR=$libDir
	make -Cbuild $jobArgs
}

INSTALL()
{
	make -Cbuild install

	prepareInstalledDevelLibs libplutosvg
	fixPkgconfig

	packageEntries devel \
		$developDir \
		$libDir/cmake
}

TEST()
{
	make -Cbuild test
}
