SUMMARY="The OpenGL Extension Wrangler Library"
DESCRIPTION="The OpenGL Extension Wrangler Library (GLEW) is a cross-platform \
open-source C/C++ extension loading library. GLEW provides efficient run-time \
mechanisms for determining which OpenGL extensions are supported on the target \
platform."
HOMEPAGE="http://glew.sourceforge.net/"
COPYRIGHT="2007 The Kronos Group Inc.
	2002-2007 Milan Ikits
	2002-2007 Marcelo E. Magallon
	2002 Lev Povalahev
	1999-2007 Brian Paul"
LICENSE="BSD (3-clause)"
REVISION="1"
SOURCE_URI="http://downloads.sourceforge.net/project/glew/glew/${portVersion}/glew-${portVersion}.tgz"
CHECKSUM_SHA256="b64790f94b926acd7e8f84c5d6000a86cb43967bd1e688b03089079799c9e889"
SOURCE_DIR="glew-$portVersion"
PATCHES="glew-$portVersion.patchset"

ARCHITECTURES="all"
SECONDARY_ARCHITECTURES="x86_gcc2 x86"

libVersion="$portVersion"
libVersionCompat="$libVersion compat >= ${libVersion%.**}"

PROVIDES="
	glew2.3$secondaryArchSuffix = $portVersion
	cmd:glewinfo = $portVersion
	cmd:visualinfo = $portVersion
	lib:libGLEW$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libGL$secondaryArchSuffix
	lib:libOSMesa$secondaryArchSuffix
	"

PROVIDES_devel="
	glew2.3${secondaryArchSuffix}_devel = $portVersion
	devel:libGLEW$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES_devel="
	glew2.3$secondaryArchSuffix == $portVersion base
	devel:libGL$secondaryArchSuffix
	devel:libOSMesa$secondaryArchSuffix
	"
CONFLICTS_devel="
	glew${secondaryArchSuffix}_devel
	glew1.13${secondaryArchSuffix}_devel
	"

PROVIDES_util="
	glew2.3${secondaryArchSuffix}_util = $portVersion
	cmd:glewinfo$secondaryArchSuffix
	cmd:visualinfo$secondaryArchSuffix
	"
REQUIRES_util="
	glew2.3$secondaryArchSuffix == $portVersion base
	$REQUIRES
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libGL$secondaryArchSuffix
	devel:libOSMesa$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:cmake
	cmd:g++$secondaryArchSuffix
	cmd:gcc$secondaryArchSuffix
	cmd:ld$secondaryArchSuffix
	cmd:libtoolize$secondaryArchSuffix
	cmd:ninja
	"

BUILD()
{
	cd build
	cmake -S cmake -DCMAKE_BUILD_TYPE=Release -G Ninja \
		$cmakeDirArgs \
		-DGLEW_OSMESA=ON \
		-DGLEW_X11=OFF
	ninja -v $jobArgs
}

INSTALL()
{
	cd build
	ninja install

	prepareInstalledDevelLib libGLEW
	fixPkgconfig

	packageEntries devel \
		$developDir \
		$libDir/cmake

	packageEntries util \
		$binDir
}
