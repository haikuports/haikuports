SUMMARY="Tiny 2D vector graphics library in C"
DESCRIPTION="PlutoVG is a standalone 2D vector graphics library in C."
HOMEPAGE="https://github.com/sammycage/plutovg"
COPYRIGHT="2020-2026 Samuel Ugochukwu"
LICENSE="MIT"
REVISION="1"
SOURCE_URI="$HOMEPAGE/archive/refs/tags/v$portVersion.tar.gz"
CHECKSUM_SHA256="7bd4e79ce18b1d47517e7e91fbb7cf19d4f01942804a519bc7c0bf32b6325dd5"
SOURCE_FILENAME="plutovg-$portVersion.tar.gz"
SOURCE_DIR="plutovg-$portVersion"

ARCHITECTURES="all ?x86_gcc2"
SECONDARY_ARCHITECTURES="?x86"

libVersion="1"
libVersionCompat="$libVersion compat >= ${libVersion%%.*}"

PROVIDES="
	plutovg$secondaryArchSuffix = $portVersion
	lib:libplutovg$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES="
	haiku$secondaryArchSuffix
	"

PROVIDES_devel="
	plutovg${secondaryArchSuffix}_devel = $portVersion
	devel:libplutovg$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES_devel="
	plutovg$secondaryArchSuffix == $portVersion base
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	"
BUILD_PREREQUIRES="
	cmd:cmake
	cmd:gcc$secondaryArchSuffix
	cmd:ld$secondaryArchSuffix
	cmd:make
	cmd:pkg_config$secondaryArchSuffix
	"

defineDebugInfoPackage plutovg$secondaryArchSuffix \
	$libDir/libplutovg.so.$libVersion

BUILD()
{
	cmake -S. -Bbuild $cmakeDirArgs -DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DBUILD_SHARED_LIBS=ON
	make -Cbuild $jobArgs
}

INSTALL()
{
	make -Cbuild install

	prepareInstalledDevelLibs libplutovg
	fixPkgconfig

	packageEntries devel \
		$developDir \
		$libDir/cmake
}
