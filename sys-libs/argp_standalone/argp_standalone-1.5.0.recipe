SUMMARY="A argp library"
DESCRIPTION="This is a continuation of Niels MĂ¶ller's work on an argp library for systems which \
don't provide one themselves (most non-GNU ones).

After noticing issues with executables built against argp-standalone 1.3, I decided to fork it \
and continue the effort.

This repository is the result of making a timeline with releases 1.0 to 1.3 obtained from \
https://www.lysator.liu.se/~nisse/misc/ of the original argp-standalone, copying files from glibc \
2.33 and fixing them up for compatibility, and finally some general clean up. I commited many \
trivial changes from the glibc version in order to make updating easier."
HOMEPAGE="https://github.com/argp-standalone/argp-standalone"
COPYRIGHT="2000-2004 Niels MĂ¶ller
	2021 Ă‰rico Nogueira
	2022 Wolf Vollprecht"
LICENSE="GNU GPL v2"
REVISION="2"
srcGitRev="8ded2bc942740b5d291e450af661c5090dc3ca38"
SOURCE_URI="$HOMEPAGE/archive/$srcGitRev.tar.gz"
CHECKSUM_SHA256="5849bba6941462ac8c3fc8ba9eec117a5e4288bc4a803eae6a6965b95caadfcf"
SOURCE_DIR="argp-standalone-$srcGitRev"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

libVersion="$portVersion"
libVersionCompat="$libVersion compat >= ${libVersion%%.*}"

PROVIDES="
	argp_standalone$secondaryArchSuffix = $portVersion
	lib:libargp$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES="
	haiku$secondaryArchSuffix
	"

PROVIDES_devel="
	argp_standalone${secondaryArchSuffix}_devel = $portVersion
	devel:libargp$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES_devel="
	argp_standalone$secondaryArchSuffix == $portVersion base
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	"
BUILD_PREREQUIRES="
	cmd:gcc$secondaryArchSuffix
	cmd:meson
	cmd:ninja
	cmd:pkg_config$secondaryArchSuffix
	"

BUILD()
{
	meson build  --buildtype=release \
		--libdir=$libDir \
		--includedir=$includeDir
	ninja -C build
}

INSTALL()
{
	ninja -C build install

	prepareInstalledDevelLib \
		libargp
	fixPkgconfig

	packageEntries devel \
		$developDir
}

TEST()
{
	ninja -C build test
}
