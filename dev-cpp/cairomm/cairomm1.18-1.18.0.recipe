SUMMARY="C++ interface for Cairo"
DESCRIPTION="a C++ wrapper for the cairo graphics library. It offers all the \
power of cairo with an interface familiar to C++ developers, including use of \
the Standard Template Library where it makes sense."
HOMEPAGE="https://www.cairographics.org/cairomm/"
COPYRIGHT="2006-2023 cairomm authors"
LICENSE="GNU LGPL v2"
REVISION="1"
SOURCE_URI="https://www.cairographics.org/releases/cairomm-$portVersion.tar.xz"
CHECKSUM_SHA256="b81255394e3ea8e8aa887276d22afa8985fc8daef60692eb2407d23049f03cfb"
SOURCE_DIR="cairomm-$portVersion"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

libVersion="1.4.0"
libVersionCompat="$libVersion compat >= ${libVersion%%.*}"
apiVersion="1.16"

PROVIDES="
	cairomm1.18$secondaryArchSuffix = $portVersion
	lib:libcairomm_$apiVersion$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libcairo$secondaryArchSuffix
	lib:libfreetype$secondaryArchSuffix
	lib:libpng16$secondaryArchSuffix
	lib:libsigc_3.0$secondaryArchSuffix
	lib:libX11$secondaryArchSuffix
	lib:libXext$secondaryArchSuffix
	lib:libz$secondaryArchSuffix
	"

PROVIDES_devel="
	cairomm1.18${secondaryArchSuffix}_devel = $portVersion
	devel:libcairomm_$apiVersion$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES_devel="
	cairomm1.18$secondaryArchSuffix == $portVersion base
	devel:libcairo$secondaryArchSuffix
	devel:libsigc_3.0$secondaryArchSuffix
	"

ARCHITECTURES_doc="any"

PROVIDES_doc="
	cairomm1.18_doc
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libcairo$secondaryArchSuffix
	devel:libsigc_3.0$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:aclocal
	cmd:autoreconf
	cmd:awk
	cmd:dot
	cmd:doxygen
	cmd:gcc$secondaryArchSuffix
	cmd:libtoolize$secondaryArchSuffix
	cmd:make
	cmd:mm_common_prepare
	cmd:pkg_config$secondaryArchSuffix
	cmd:xsltproc
	"

defineDebugInfoPackage cairomm1.18$secondaryArchSuffix \
	"$libDir"/libcairomm-$apiVersion.so.$libVersion

BUILD()
{
	./autogen.sh
	runConfigure ./configure
	make $jobArgs
}

INSTALL()
{
	make install

	# move documentation
	mkdir -p $documentationDir/packages
	mv $dataDir/{devhelp,doc/cairomm-$apiVersion} $documentationDir/packages
	# cleanup
	rm -rf $dataDir

	# remove libtool file
	rm -rf $libDir/*.la

	mv $libDir/cairomm-$apiVersion/include/*.h $includeDir/cairomm-$apiVersion
	rm -rf $libDir/cairomm-$apiVersion

	prepareInstalledDevelLibs \
		libcairomm-$apiVersion

	fixPkgconfig

	sed -i -e 's|-I${libdir}/cairomm-$apiVersion/include||' \
		$developLibDir/pkgconfig/cairomm-$apiVersion.pc

	packageEntries devel \
		$developDir

	packageEntries doc \
		$documentationDir
}
