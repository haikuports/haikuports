SUMMARY="Program which allows running Microsoft Windows programs"
DESCRIPTION="Wine is a program which allows running Microsoft Windows programs \
(including DOS, Windows 3.x, Win32, and Win64 executables) on Unix. \
Wine on Haiku can only run Win64 executables as of this version."
HOMEPAGE="https://www.winehq.org/"
COPYRIGHT="1993-2026 the Wine project authors"
LICENSE="GNU LGPL v2.1"
REVISION="1"
SOURCE_URI="https://github.com/wine-mirror/wine/archive/refs/tags/wine-${portVersion}.tar.gz"
CHECKSUM_SHA256="4bf5a72ec59b70f3893bf596d11668d8bc487f276b0bf52a2b60a0be52a674c3"
SOURCE_DIR="wine-wine-${portVersion}"
PATCHES="wine-$portVersion.patchset"
ADDITIONAL_FILES="wine.rdef.in"

ARCHITECTURES="all !x86_gcc2"
#SECONDARY_ARCHITECTURES="x86" # Untested

PROVIDES="
	wine$secondaryArchSuffix = $portVersion
	cmd:wine$secondaryArchSuffix = $portVersion
	cmd:function_grep.pl
	cmd:msidb
	cmd:msiexec
	cmd:notepad
	cmd:regedit
	cmd:regsvr32
	cmd:widl
	cmd:wineboot
	cmd:winebuild
	cmd:winecfg
	cmd:wineconsole
	cmd:winecpp
	cmd:winedbg
	cmd:winedump
	cmd:winefile
	cmd:wineg++
	cmd:winegcc
	cmd:winemaker
	cmd:winemine
	cmd:winepath
	cmd:wineserver
	cmd:wmc
	cmd:wrc
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libfreetype$secondaryArchSuffix
	lib:libusb$secondaryArchSuffix
	lib:libvulkan$secondaryArchSuffix
	"
REPLACES="
	wine_bin
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	ffmpeg6${secondaryArchSuffix}_devel # Optional, min. v6 required
	gstreamer${secondaryArchSuffix}_devel # Optional
	gst_plugins_base${secondaryArchSuffix}_devel # Optional
	libgphoto2${secondaryArchSuffix}_devel # Optional
	libpcap${secondaryArchSuffix}_devel # Optional
	libusb${secondaryArchSuffix}_devel # Optional
	opensound$secondaryArchSuffix # Optional, for audio support
	samba4${secondaryArchSuffix}_devel # Optional
	sane_backends${secondaryArchSuffix}_devel # Optional
	devel:libdbus_1$secondaryArchSuffix # Optional
	devel:libEGL$secondaryArchSuffix # Optional, used with wayland
	devel:libfontconfig$secondaryArchSuffix # Optional
	devel:libfreetype$secondaryArchSuffix
	devel:libgnutls$secondaryArchSuffix
	devel:libkrb5$secondaryArchSuffix # Optional
	devel:libopenal$secondaryArchSuffix # Optional
	devel:libopencl$secondaryArchSuffix # Optional
	devel:libopencl_headers$secondaryArchSuffix # Optional
	devel:libSDL2_2.0$secondaryArchSuffix # Optional
	devel:libvulkan$secondaryArchSuffix
	devel:libwayland_egl$secondaryArchSuffix
	devel:libwayland_client$secondaryArchSuffix
	#devel:libX11$secondaryArchSuffix # xLibe_devel, needed if built --with-x
	devel:libxkbcommon$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:autoconf
	cmd:automake
	cmd:bison
	cmd:cp
	cmd:flex
	cmd:gcc
	cmd:gettext
	cmd:ld
	cmd:make
	cmd:mkdepend
	cmd:sed
	cmd:pkg_config
	llvm21
	llvm21_clang
	llvm21_lld
	"

BUILD()
{
	autoreconf -i
	LDFLAGS=-lnetwork runConfigure ./configure \
		--enable-archs=i386,x86_64 \
		--disable-tests \
		--with-wayland --without-x

	make $jobArgs
}

INSTALL()
{
	make install

	# Generate the rdef
	local MAJOR="`echo "$portVersion" | cut -d. -f1`"
	local MIDDLE="`echo "$portVersion" | cut -d. -f2`"
	local LONG_INFO="$SUMMARY"
	sed \
		-e "s|@MAJOR@|$MAJOR|" \
		-e "s|@MIDDLE@|$MIDDLE|" \
		-e "s|@LONG_INFO@|$LONG_INFO|" \
		$portDir/additional-files/wine.rdef.in > wine.rdef

	addResourcesToBinaries wine.rdef $prefix/bin/wine # For Deskbar menu links
	addResourcesToBinaries wine.rdef $prefix/lib/wine/x86_64-unix/wine # For the actual Deskbar app entry

	# Make the main bin name uppercase then link it back
	mv $prefix/lib/wine/x86_64-unix/wine $prefix/lib/wine/x86_64-unix/Wine
	ln -s $prefix/lib/wine/x86_64-unix/Wine $prefix/lib/wine/x86_64-unix/wine

	# This link doesn't work when invoked from the Deskbar menu
	#addPreferencesDeskbarSymlink $prefix/bin/winecfg "Wine Configuration"
}
