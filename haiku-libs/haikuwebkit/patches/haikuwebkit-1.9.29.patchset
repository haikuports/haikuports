Date: Tue, 2 Jun 2026 21:04:22 +0200
Subject: patch for x86


diff --git a/Source/bmalloc/libpas/src/libpas/pas_utils.h b/Source/bmalloc/libpas/src/libpas/pas_utils.h
index 433b26f..eb0133c 100644
--- a/Source/bmalloc/libpas/src/libpas/pas_utils.h
+++ b/Source/bmalloc/libpas/src/libpas/pas_utils.h
@@ -920,7 +920,7 @@ static PAS_ALWAYS_INLINE uintptr_t pas_opaque(uintptr_t value)
     return value;
 }
 
-#if PAS_COMPILER(CLANG) || PAS_ARM32
+#if PAS_COMPILER(CLANG) || PAS_ARM32 || !defined(__SIZEOF_INT128__)
 
 struct pas_pair;
 typedef struct pas_pair pas_pair;
