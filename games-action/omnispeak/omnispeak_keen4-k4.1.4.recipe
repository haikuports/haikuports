SUMMARY="Omnispeak - Commander Keen 4 data"
DESCRIPTION="Commander Keen 4 data files, released in 1991 as shareware, \
packaged to be used with the Omnispeak binaries."
HOMEPAGE="https://legacy.3drealms.com/keen4/"
COPYRIGHT="1991 Id Software, Apogee Inc."
#No Shareware license?
LICENSE="Public Domain"
REVISION="1"
SOURCE_URI="https://davidgow.net/keen/4keen14.zip"
CHECKSUM_SHA256="f92e2d02d3779a2e717a50287ef3ed116c22fdf7bcc12ccf676a412e97195cfe"
SOURCE_DIR=""
ADDITIONAL_FILES="
	omnispeak.rdef.in
	omni-keen4.sh
	"

#should be ARCHITECTURES="any" and no secondary eventually
ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURE="x86"

PROVIDES="
	omnispeak_keen4$secondaryArchSuffix = $portVersion
	"
REQUIRES="
	omnispeak$secondaryArchSuffix
	"

INSTALL()
{
	#Pack game data
	mkdir -p $dataDir/omnispeak/keen4 && cp -r -t $dataDir/omnispeak/keen4 *.CK4 *.ck4
	
	#Pack script
	cp $portDir/additional-files/omni-keen4.sh $dataDir/omnispeak
	chmod +x $dataDir/omnispeak/omni-keen4.sh

	# Generate the rdef
	local MAJOR="`echo "$portVersion" | cut -b4`"
	local MIDDLE="`echo "$portVersion" | cut -b6`"
	local MINOR="0"
	local LONG_INFO="$SUMMARY"
	sed \
		-e "s|@MAJOR@|$MAJOR|" \
		-e "s|@MIDDLE@|$MIDDLE|" \
		-e "s|@MINOR@|$MINOR|" \
		-e "s|@LONG_INFO@|$LONG_INFO|" \
		$portDir/additional-files/omnispeak.rdef.in > omnispeak-keen4.rdef

	#Iconize & link script
	rc omnispeak-keen4.rdef
	resattr -o $dataDir/omnispeak/omni-keen4.sh omnispeak-keen4.rsrc
	addAppDeskbarSymlink $dataDir/omnispeak/omni-keen4.sh "Omnispeak - Keen 4"
}
