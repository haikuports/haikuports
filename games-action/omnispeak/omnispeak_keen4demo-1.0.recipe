SUMMARY="Omnispeak - Commander Keen 4 Demo"
DESCRIPTION="Commander Keen 4 demo data files packaged to be used with the Omnispeak binaries, \
The needed files will be linked at '~/config/non-packaged/data/omnispeak' automatically."
HOMEPAGE="https://davidgow.net/keen/omnispeak.html"
COPYRIGHT="1991 Id Software"
#No Shareware license?
LICENSE="Public Domain"
REVISION="1"
SOURCE_URI="https://davidgow.net/keen/4keen14.zip"
CHECKSUM_SHA256="f92e2d02d3779a2e717a50287ef3ed116c22fdf7bcc12ccf676a412e97195cfe"
SOURCE_DIR=""
ADDITIONAL_FILES="keen4demo-postinstall.sh"
POST_INSTALL_SCRIPTS="$relativePostInstallDir/keen4demo-postinstall.sh"

#should be ARCHITECTURES="any" and no secondary eventually
ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURE="x86"

PROVIDES="
	omnispeak_keen4demo$secondaryArchSuffix = $portVersion
	"
REQUIRES="
	omnispeak$secondaryArchSuffix
	"

INSTALL()
{
	#Pack game data
	mkdir -p $dataDir/omnispeak/keen4demo && cp -r -t $dataDir/omnispeak/keen4demo *.CK4 *.ck4

	# Setup post-install script (to link the game data files)
	mkdir -p $postInstallDir
	cp $portDir/additional-files/keen4demo-postinstall.sh $postInstallDir
	chmod +x $postInstallDir/keen4demo-postinstall.sh
}
