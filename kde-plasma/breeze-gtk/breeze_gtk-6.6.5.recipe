SUMMARY="Breeze for GTK"
DESCRIPTION="Gnome-breeze, a GTK Theme Built to Match KDE's Breeze."
HOMEPAGE="https://invent.kde.org/plasma/breeze-gtk"
COPYRIGHT="2010-2026 KDE Organisation"
LICENSE="BSD (3-clause)
	CC0-1.0"
REVISION="1"
SOURCE_URI="https://download.kde.org/stable/plasma/$portVersion/breeze-gtk-$portVersion.tar.xz"
CHECKSUM_SHA256="76caad4ca2e3ce8b02ae1ebe0c068101bb07db51da47f88fa3a40cdce393abf6"
SOURCE_DIR="breeze-gtk-$portVersion"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="?x86"

PROVIDES="
	breeze_gtk$secondaryArchSuffix = $portVersion
	"
REQUIRES="
	haiku$secondaryArchSuffix
	# Plasma
	breeze6$secondaryArchSuffix
	# Qt6
	lib:libQt6Core$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	# KF6
	extra_cmake_modules$secondaryArchSuffix
	# Plasma
	devel:breeze6$secondaryArchSuffix == $portVersion
	# Qt6
	devel:libQt6Core$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	pycairo_python310
	cmd:cmake
	cmd:g++$secondaryArchSuffix
	cmd:make
	cmd:python3
	cmd:sassc$secondaryArchSuffix
	"

BUILD()
{
	cmake -B build -S . -DCMAKE_BUILD_TYPE=Release \
		$cmakeDirArgs

	make -C build $jobArgs
}

INSTALL()
{
	make -C build install

	# only keep GTK4 themes
	rm -rf $dataDir/themes/Breeze/{gtk-3.0,gtk-2.0}
	rm -rf $dataDir/themes/Breeze-Dark/{gtk-3.0,gtk-2.0}

	# yellow tab
	sed -i -e 's|#e3e5e7|#ffda00|g' $dataDir/themes/Breeze/gtk-4.0/gtk.css
	sed -i -e 's|#272c31|#ffda00|g' $dataDir/themes/Breeze-Dark/gtk-4.0/gtk.css
}
