SUMMARY="A simple editor for simple need"
DESCRIPTION="This editor pays homage to the classic MS-DOS Editor, but with a modern interface \
and input controls similar to VS Code. The goal is to provide an accessible editor that even \
users largely unfamiliar with terminals can easily use."
HOMEPAGE="https://github.com/microsoft/edit"
COPYRIGHT="2026 Microsoft Corporation"
LICENSE="MIT"
REVISION="1"
SOURCE_URI="https://github.com/microsoft/edit/archive/refs/tags/v$portVersion.tar.gz"
CHECKSUM_SHA256="f35da309c5f3d92b10e5c4b2267e4d5e29d809b2aa460e80326b11f7feba72a5"
SOURCE_DIR="edit-$portVersion"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	msedit$secondaryArchSuffix = $portVersion
	cmd:msedit = $portVersion
	"
REQUIRES="
	haiku$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	"
BUILD_PREREQUIRES="
	cmd:cargo$secondaryArchSuffix
	cmd:gcc$secondaryArchSuffix
	"

BUILD()
{
	export PKG_CONFIG_ALLOW_CROSS=1
	export RUSTC_BOOTSTRAP=1

	cargo fetch
	cargo build --release --frozen
}

INSTALL()
{
	install -d $prefix/bin $manDir/man1
	cp target/release/edit $prefix/bin/msedit
	cp assets/manpage/edit.1 $manDir/man1/msedit.1
}
