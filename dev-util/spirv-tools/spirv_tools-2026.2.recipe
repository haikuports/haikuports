SUMMARY="API and commands for processing SPIR-V modules"
DESCRIPTION="SPIR-V enables high-level language front-ends to emit programs in a standardized \
intermediate form to be ingested by a wider range of drivers, including Vulkan, OpenGL and \
OpenCL. SPIR-V eliminates the need for high-level language front-end compilers in device drivers, \
significantly reducing driver complexity and enabling a broad range of language and framework \
front-ends to run on diverse hardware architectures and encourages a vibrant ecosystem of open \
source analysis, porting, debug and optimization tools.

For developers, using SPIR-V means that kernel source code no longer has to be directly exposed, \
kernel load times can be accelerated, and developers can choose the use of a common language \
front-end compiler, improving kernel reliability and portability across multiple hardware \
implementations."
HOMEPAGE="https://www.khronos.org/spirv/"
COPYRIGHT="2026 The Khronos® Group Inc."
LICENSE="Apache v2"
REVISION="1"
SOURCE_URI="https://github.com/KhronosGroup/SPIRV-Tools/archive/refs/tags/v$portVersion.tar.gz"
CHECKSUM_SHA256="b4390652e64ab188eede9d556cf183b3c1c4be44d4fcd104b0d4af3bea2712d1"
SOURCE_FILENAME="spirv-tools-v$portVersion.tar.gz"
SOURCE_DIR="SPIRV-Tools-$portVersion"
PATCHES="spirv_tools-$portVersion.patchset"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	spirv_tools$secondaryArchSuffix = $portVersion
	cmd:spirv_as = $portVersion
	cmd:spirv_cfg = $portVersion
	cmd:spirv_diff = $portVersion
	cmd:spirv_dis = $portVersion
	cmd:spirv_lesspipe.sh = $portVersion
	cmd:spirv_link = $portVersion
	cmd:spirv_lint = $portVersion
	cmd:spirv_objdump = $portVersion
	cmd:spirv_opt = $portVersion
	cmd:spirv_reduce = $portVersion
	cmd:spirv_val = $portVersion
	lib:libSPIRV_Tools$secondaryArchSuffix
	lib:libSPIRV_Tools_diff$secondaryArchSuffix
	lib:libSPIRV_Tools_link$secondaryArchSuffix
	lib:libSPIRV_Tools_lint$secondaryArchSuffix
	lib:libSPIRV_Tools_opt$secondaryArchSuffix
	lib:libSPIRV_Tools_reduce$secondaryArchSuffix
	lib:libSPIRV_Tools_shared$secondaryArchSuffix
	"
REQUIRES="
	haiku$secondaryArchSuffix
	"

PROVIDES_devel="
	spirv_tools${secondaryArchSuffix}_devel = $portVersion
	devel:libSPIRV_Tools$secondaryArchSuffix
	devel:libSPIRV_Tools_diff$secondaryArchSuffix
	devel:libSPIRV_Tools_link$secondaryArchSuffix
	devel:libSPIRV_Tools_lint$secondaryArchSuffix
	devel:libSPIRV_Tools_opt$secondaryArchSuffix
	devel:libSPIRV_Tools_reduce$secondaryArchSuffix
	devel:libSPIRV_Tools_shared$secondaryArchSuffix
	"
REQUIRES_devel="
	spirv_tools$secondaryArchSuffix == $portVersion base
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:spirv_headers$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:cmake
	cmd:gcc$secondaryArchSuffix
	cmd:make
	cmd:pkg_config$secondaryArchSuffix
	cmd:python3
	"

BUILD()
{
	cmake -B build -S . -DCMAKE_BUILD_TYPE=Release \
		$cmakeDirArgs \
		-DCMAKE_INSTALL_BINDIR=$prefix/bin \
		-DSPIRV-Headers_SOURCE_DIR="$(finddir B_SYSTEM_HEADERS_DIRECTORY)$secondaryArchSubDir/" \
		-DBUILD_SHARED_LIBS=ON \
		-DSPIRV_TOOLS_BUILD_STATIC=OFF \
		-DSPIRV_SKIP_TESTS=ON \
		-DCMAKE_SKIP_RPATH=ON

	make -C build $jobArgs
}

INSTALL()
{
	make -C build install

	prepareInstalledDevelLibs \
		libSPIRV-Tools \
		libSPIRV-Tools-diff \
		libSPIRV-Tools-link \
		libSPIRV-Tools-lint \
		libSPIRV-Tools-opt \
		libSPIRV-Tools-reduce \
		libSPIRV-Tools-shared
	fixPkgconfig

	packageEntries devel \
		$developDir \
		$libDir/cmake
}
