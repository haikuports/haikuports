SUMMARY="Produces a document with syntax highlighting"
DESCRIPTION="This can convert source code to a syntax highlighted document."
HOMEPAGE="https://www.gnu.org/software/src-highlite/"
COPYRIGHT="1999-2009 Lorenzo Bettini"
LICENSE="GNU GPL v3"
REVISION="2"
SOURCE_URI="https://ftp.gnu.org/gnu/src-highlite/source-highlight-$portVersion.tar.gz"
CHECKSUM_SHA256="3a7fd28378cb5416f8de2c9e77196ec915145d44e30ff4e0ee8beb3fe6211c91"
SOURCE_DIR="source-highlight-$portVersion"
PATCHES="source_highlight-$portVersion.patchset"

ARCHITECTURES="x86_64"

GLOBAL_WRITABLE_FILES="
	settings/bash_completion.d/source-highlight keep-old
	"

libVersion="4.0.1"
libVersionCompat="$libVersion compat >= ${libVersion%%.*}"


PROVIDES="
	source_highlight = $portVersion
	lib:libsource_highlight = $libVersionCompat
	cmd:check_regexp
	cmd:cpp2html
	cmd:java2html
	cmd:source_highlight
	cmd:source_highlight_esc.sh
	cmd:source_highlight_settings
	cmd:src_hilite_lesspipe.sh
	"
REQUIRES="
	haiku
	lib:libboost_regex
	"

PROVIDES_devel="
	source_highlight_devel = $portVersion
	devel:libsource_highlight = $libVersionCompat
	"
REQUIRES_devel="
	source_highlight == $portVersion base
	haiku_devel
	devel:libboost_regex
	"

BUILD_REQUIRES="
	haiku_devel
	devel:libboost_regex >= 1.83.0
	"
BUILD_PREREQUIRES="
	cmd:awk
	cmd:bison
	cmd:diff
	cmd:flex
	cmd:gcc
	cmd:ld
	cmd:make
	"

BUILD()
{
	mkdir -p build && cd build

	runConfigure ../configure \
		--with-boost-libdir=/system/develop/lib/
	make $jobArgs
}

INSTALL()
{
	make -C build install

	rm $libDir/*.a $libDir/*.la

	prepareInstalledDevelLibs libsource-highlight
	fixPkgconfig

	packageEntries devel \
		"$developDir"

	echo -e "\nrecipe = sh.lang" >> $dataDir/source-highlight/lang.map
}
