SUMMARY="A free and open-source cross-platform source explorer"
DESCRIPTION="Sourcetrail helps you get productive on unfamiliar source code"
HOMEPAGE="https://www.sourcetrail.com/
	https://github.com/petermost/Sourcetrail"
COPYRIGHT="2019 Andreas Stallinger and others
	2024-2026 Peter Most"
LICENSE="GNU GPL v3"
REVISION="1"
srcGitRev="58a3db3f6af4b6c18cda525900392469739fe83b"
SOURCE_URI="https://github.com/petermost/Sourcetrail/archive/$srcGitRev.tar.gz"
CHECKSUM_SHA256="6895bc7ef6121a9d8c6a9bc5b4368ea067a613b59236843ad89676efe8ba0a31"
SOURCE_FILENAME="sourcetrail-$portVersion.tar.gz"
SOURCE_DIR="Sourcetrail-$srcGitRev"
ADDITIONAL_FILES="sourcetrail.rdef.in"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

clangVer="20"
#jdkVer=21
boostMinimumVersion="1.90.0"

PROVIDES="
	sourcetrail$secondaryArchSuffix = $portVersion
 	app:sourcetrail
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libclang_cpp$secondaryArchSuffix
	lib:libboost_atomic$secondaryArchSuffix
	lib:libboost_charconv$secondaryArchSuffix
	lib:libboost_chrono$secondaryArchSuffix
	lib:libboost_container$secondaryArchSuffix
	lib:libboost_date_time$secondaryArchSuffix
	lib:libboost_filesystem$secondaryArchSuffix
	lib:libboost_locale$secondaryArchSuffix
	lib:libboost_program_options$secondaryArchSuffix
	lib:libboost_thread$secondaryArchSuffix
	lib:libGL$secondaryArchSuffix
	lib:libicudata$secondaryArchSuffix
	lib:libicui18n$secondaryArchSuffix
	lib:libicuuc$secondaryArchSuffix
	lib:libLLVM$secondaryArchSuffix
	lib:libQt6Core$secondaryArchSuffix
	lib:libQt6Gui$secondaryArchSuffix
	lib:libQt6Network$secondaryArchSuffix
	lib:libQt6Svg$secondaryArchSuffix
	lib:libQt6Widgets$secondaryArchSuffix
	lib:libsqlite3$secondaryArchSuffix
	lib:libtinyxml$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libclang_cpp$secondaryArchSuffix >= $clangVer
	devel:libboost_filesystem$secondaryArchSuffix >= $boostMinimumVersion
	devel:libicuuc$secondaryArchSuffix >= 74
	devel:libLLVM$secondaryArchSuffix >= $clangVer
	devel:libomp$secondaryArchSuffix
	devel:libQt6Core$secondaryArchSuffix
	devel:libQt6Svg$secondaryArchSuffix
	devel:libsqlite3$secondaryArchSuffix
	devel:libtinyxml$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
#	java:runtime == $jdkVer
	cmd:cmake
	cmd:clang >= $clangVer
	cmd:gcc$secondaryArchSuffix
#	cmd:javac >= $jdkVer
	cmd:ninja
	cmd:pkg_config$secondaryArchSuffix
	"

BUILD()
{
	export CC=clang
	export CXX=clang++
	export LDFLAGS="$(sed -E -e 's/\S*fuse-ld\S*//g' <<< "$LDFLAGS") -fuse-ld=lld"

	export PATH="$(finddir B_SYSTEM_DEVELOP_DIRECTORY)/lib$secondaryArchSubDir/llvm${clangVer:-}/bin:$PATH"
	export LD_LIBRARY_PATH="$(finddir B_SYSTEM_DEVELOP_DIRECTORY)/lib$secondaryArchSubDir/llvm${clangVer:-}/lib"

	export Clang_DIR="$(finddir B_SYSTEM_DEVELOP_DIRECTORY)/lib$secondaryArchSubDir/llvm${clangVer:-}/cmake/clang"
	export LLVM_DIR="$(finddir B_SYSTEM_DEVELOP_DIRECTORY)/lib$secondaryArchSubDir/llvm${clangVer:-}/cmake/llvm"

#	export JAVA_HOME="$(finddir B_SYSTEM_DEVELOP_DIRECTORY)/lib$secondaryArchSubDir/jvm/java-${jdkVer}-openjdk"

	local _cmake_options=(
		-B build
		-S .
		-G Ninja
		-DCMAKE_BUILD_TYPE=None
		-DCMAKE_CXX_FLAGS="-D_GNU_SOURCE"
		-DBUILD_CXX_LANGUAGE_PACKAGE=ON
		-DBUILD_JAVA_LANGUAGE_PACKAGE=OFF
		-DBUILD_UNIT_TESTS_PACKAGE=OFF
		-DCMAKE_EXPORT_COMPILE_COMMANDS=ON
		-DCMAKE_VERBOSE_MAKEFILE=OFF
		-Wno-dev
	)

	cmake "${_cmake_options[@]}"
	cmake --build build
}

INSTALL()
{
	cd build
	mkdir -p $appsDir/SourceTrail
	cp -rf ../bin/app/* $appsDir/SourceTrail
	cp app/Sourcetrail $appsDir/SourceTrail
	cp app/sourcetrail_indexer $appsDir/SourceTrail

	local MAJOR="`echo "$portVersion" | cut -d. -f1`"
	local MIDDLE="`echo "$portVersion" | cut -d. -f2`"
	local MINOR="`echo "$portVersion" | cut -d. -f3 | cut -d~ -f1`"
	local APP_NAME="Sourcetrail"
	local LONG_INFO="$SUMMARY"
	local APP_SIGNATURE="application/x-vnd.sourcetrail"
	sed \
		-e "s|@MAJOR@|$MAJOR|" \
		-e "s|@MIDDLE@|$MIDDLE|" \
		-e "s|@MINOR@|$MINOR|" \
		-e "s|@LONG_INFO@|$LONG_INFO|" \
		-e "s|@APP_NAME@|$APP_NAME|" \
		-e "s|@APP_SIGNATURE@|$APP_SIGNATURE|" \
		$portDir/additional-files/sourcetrail.rdef.in > sourcetrail.rdef

	addResourcesToBinaries sourcetrail.rdef $appsDir/SourceTrail/Sourcetrail
	addAppDeskbarSymlink $appsDir/SourceTrail/Sourcetrail
}
