From adebce5c666b2c94602e602ff43cd7f70143dda1 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?J=C3=A9r=C3=B4me=20Duval?= <jerome.duval@gmail.com>
Date: Sun, 28 Jun 2026 18:09:20 +0200
Subject: implement Path::getCurrentExecutablePath for Haiku


diff --git a/Makefile b/Makefile
index 7d2b451..0fc1d8e 100644
--- a/Makefile
+++ b/Makefile
@@ -132,11 +132,9 @@ ifeq (clang++, $(findstring clang++,$(CXX)))
     CPPCHK_GLIBCXX_DEBUG=
 endif
 ifndef CXXFLAGS
-    CXXFLAGS=-O2 -Wall -Wno-sign-compare -Wno-multichar
+    CXXFLAGS=-pedantic -Wall -Wextra -Wcast-qual -Wfloat-equal -Wmissing-declarations -Wmissing-format-attribute -Wno-long-long -Wpacked -Wredundant-decls -Wundef -Wno-sign-compare -Wno-multichar -Woverloaded-virtual -g
 endif
 
-override CPPFLAGS += -DNDEBUG
-
 ifeq (g++, $(findstring g++,$(CXX)))
     override CXXFLAGS += -pipe
 endif
@@ -398,7 +396,7 @@ dmake:	tools/dmake/dmake.o cli/filelister.o $(libcppdir)/pathmatch.o $(libcppdir
 	$(CXX) $(CXXFLAGS) -o $@ $^ $(LDFLAGS)
 
 run-dmake: dmake
-	./dmake --release
+	./dmake
 
 clean:
 	rm -f build/*.cpp build/*.o lib/*.o cli/*.o frontend/*.o test/*.o tools/dmake/*.o externals/*/*.o testrunner dmake cppcheck cppcheck.exe cppcheck.1
diff --git a/lib/path.cpp b/lib/path.cpp
index c4758df..0195c8b 100644
--- a/lib/path.cpp
+++ b/lib/path.cpp
@@ -52,6 +52,9 @@
 #if defined(__APPLE__)
 #include <mach-o/dyld.h>
 #endif
+#if defined(__HAIKU__)
+#include <image.h>
+#endif
 
 
 /** Is the filesystem case insensitive? */
@@ -158,6 +161,17 @@ std::string Path::getCurrentExecutablePath(const char* fallback)
 #elif defined(__APPLE__)
     uint32_t size = sizeof(buf);
     success = (_NSGetExecutablePath(buf, &size) == 0);
+#elif defined(__HAIKU__)
+	int32 cookie = 0;
+	image_info info;
+	while (get_next_image_info(B_CURRENT_TEAM, &cookie, &info) == B_OK)
+	{
+		if (info.type == B_APP_IMAGE)
+		{
+			break;
+		}
+	}
+	return std::string(info.name);
 #else
     const char* procPath =
 #ifdef __SVR4 // Solaris
-- 
2.54.0

