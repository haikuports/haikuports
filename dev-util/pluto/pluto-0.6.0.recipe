SUMMARY="A native Haiku AI client with CLI, GUI, and Tracker add-on"
DESCRIPTION="Pluto is an AI client for Haiku. It works with local open-source \
models via Ollama and LM Studio, as well as cloud providers like OpenRouter, \
Groq, and Google Gemini. Includes tools for file I/O, shell commands, BFS \
attributes, filesystem queries, and desktop scripting via BMessage."
HOMEPAGE="https://codeberg.org/atomozero/Pluto"
COPYRIGHT="2026 atomozero"
LICENSE="MIT"
REVISION="1"
SOURCE_URI="https://codeberg.org/atomozero/Pluto/archive/v$portVersion.tar.gz"
CHECKSUM_SHA256="65d339100100d29ab5f0671f83bda05f37d7a8513c06226dada97155a332822c"
SOURCE_DIR="pluto"

ARCHITECTURES="all !x86_gcc2"

PROVIDES="
	pluto = $portVersion
	app:Pluto = $portVersion
	cmd:Pluto_cli = $portVersion
	"
REQUIRES="
	haiku
	lib:libcurl
	lib:libcrypto
	lib:libedit
	lib:libssl
	"

BUILD_REQUIRES="
	haiku_devel
	devel:libcurl
	devel:libcrypto
	devel:libedit
	devel:libssl
	"
BUILD_PREREQUIRES="
	cmd:gcc
	cmd:make
	cmd:rc
	"

BUILD()
{
	make $jobArgs
}

INSTALL()
{
	mkdir -p $binDir
	cp Pluto_cli $binDir/Pluto_cli

	mkdir -p $appsDir
	cp Pluto "$appsDir/Pluto"
	addAppDeskbarSymlink "$appsDir/Pluto" "Pluto"

	mkdir -p "$addOnsDir/Tracker"
	cp 'Ask pluto' "$addOnsDir/Tracker/Ask pluto"

	mkdir -p $manDir/man1
	cp docs/pluto.1 $manDir/man1/pluto.1

	mkdir -p $dataDir/pluto/providers
	cp data/beapi-index.jsonl $dataDir/pluto/
	cp data/lsp.conf $dataDir/pluto/
	cp data/providers/*.conf $dataDir/pluto/providers/

	mkdir -p $docDir
	cp README.md CHANGELOG.md $docDir/
	cp docs/user-guide.md docs/architecture.md $docDir/
	cp docs/mcp-tutorial.md docs/bquery-cookbook.md $docDir/

	mkdir -p $docDir/examples
	cp -r examples/agents examples/routines examples/providers $docDir/examples/
}

TEST()
{
	make check
}
