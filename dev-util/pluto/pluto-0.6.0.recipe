SUMMARY="Haiku-native AI client (CLI + GUI + Tracker add-on)"
DESCRIPTION="Pluto is a native Haiku AI client written in C++17 against \
libcurl and the Be API. It supports 15+ providers (Anthropic, OpenAI, \
Gemini, OpenRouter, Ollama, and more) and ships as three binaries: a \
streaming REPL (Pluto_cli), a GUI with multi-tab conversations and \
markdown rendering (Pluto), and a Tracker add-on for right-click AI \
queries (Ask pluto). Features include 23 built-in tools, MCP client \
support, BFS attribute integration, BeAPI knowledge base, routines, \
agent store, and sessions searchable from Tracker's Find dialog."
HOMEPAGE="https://codeberg.org/atomozero/Pluto"
COPYRIGHT="2026 atomozero"
LICENSE="MIT"
REVISION="1"
SOURCE_URI="https://codeberg.org/atomozero/Pluto/archive/v$portVersion.tar.gz"
CHECKSUM_SHA256="65d339100100d29ab5f0671f83bda05f37d7a8513c06226dada97155a332822c"
SOURCE_DIR="pluto"

ARCHITECTURES="all !x86_gcc2"

PROVIDES="
	pluto = $portVersion
	app:Pluto = $portVersion
	cmd:Pluto_cli = $portVersion
	"
REQUIRES="
	haiku
	lib:libcurl
	lib:libcrypto
	lib:libedit
	lib:libssl
	"

BUILD_REQUIRES="
	haiku_devel
	devel:libcurl
	devel:libcrypto
	devel:libedit
	devel:libssl
	"
BUILD_PREREQUIRES="
	cmd:gcc
	cmd:make
	cmd:rc
	"

BUILD()
{
	make $jobArgs
}

INSTALL()
{
	# CLI binary
	mkdir -p $binDir
	cp Pluto_cli $binDir/Pluto_cli

	# GUI binary
	mkdir -p $appsDir
	cp Pluto "$appsDir/Pluto"
	addAppDeskbarSymlink "$appsDir/Pluto" "Pluto"

	# Tracker add-on
	mkdir -p "$addOnsDir/Tracker"
	cp 'Ask pluto' "$addOnsDir/Tracker/Ask pluto"

	# Man page
	mkdir -p $manDir/man1
	cp docs/pluto.1 $manDir/man1/pluto.1

	# Data files (BeAPI index, LSP config, provider profiles)
	mkdir -p $dataDir/pluto/providers
	cp data/beapi-index.jsonl $dataDir/pluto/
	cp data/lsp.conf $dataDir/pluto/
	cp data/providers/*.conf $dataDir/pluto/providers/

	# Documentation
	mkdir -p $docDir
	cp README.md $docDir/
	cp CHANGELOG.md $docDir/
	cp docs/user-guide.md $docDir/
	cp docs/architecture.md $docDir/
	cp docs/mcp-tutorial.md $docDir/
	cp docs/bquery-cookbook.md $docDir/

	# Examples
	mkdir -p $docDir/examples/agents
	cp -r examples/agents/* $docDir/examples/agents/
	mkdir -p $docDir/examples/routines
	cp examples/routines/*.md $docDir/examples/routines/
	mkdir -p $docDir/examples/providers
	cp examples/providers/*.conf $docDir/examples/providers/
	cp examples/providers/TEMPLATE.conf $docDir/examples/providers/
}

TEST()
{
	make check
}
