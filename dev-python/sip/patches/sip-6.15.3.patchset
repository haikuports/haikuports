From c4e4a1f91cbf875b3b862dd85295a5d2882dbfbe Mon Sep 17 00:00:00 2001
From: Oscar Lesta <oscar.lesta@gmail.com>
Date: Thu, 21 May 2026 15:37:06 -0300
Subject: Use correct include/headers dir on Haiku.


diff --git a/sipbuild/project.py b/sipbuild/project.py
index caedef0..919e59f 100644
--- a/sipbuild/project.py
+++ b/sipbuild/project.py
@@ -60,7 +60,7 @@ class Project(AbstractProject, Configurable):
         Option('py_debug', option_type=bool),
 
         # The name of the directory containing Python.h.
-        Option('py_include_dir', default=sysconfig.get_path('include')),
+        Option('py_include_dir', default=sysconfig.get_path('include', scheme="haiku_vendor")),
 
         # The name of the target Python platform.
         Option('py_platform'),
-- 
2.52.0

