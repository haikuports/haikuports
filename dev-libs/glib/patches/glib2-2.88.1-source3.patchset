From dd38b0a8691bc042928da0cc908d43ee05d43ed1 Mon Sep 17 00:00:00 2001
From: begasus <begasus@gmail.com>
Date: Wed, 18 Dec 2019 15:22:46 +0000
Subject: Use objdump -x instead of ldd


diff --git a/giscanner/shlibs.py b/giscanner/shlibs.py
index 66cbb25..5aac499 100644
--- a/giscanner/shlibs.py
+++ b/giscanner/shlibs.py
@@ -102,6 +102,8 @@ def _resolve_non_libtool(options, binary, libraries):
             args.append(binary.args[0])
         elif platform_system == 'Darwin':
             args.extend(['otool', '-L', binary.args[0]])
+        elif platform_system == 'Haiku':
+            args.extend(['objdump', '-x', binary.args[0]])
         else:
             args.extend(['ldd', binary.args[0]])
         output = subprocess.check_output(args)
-- 
2.52.0

