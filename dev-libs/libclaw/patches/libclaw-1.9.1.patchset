From 18d88ab50ac573c48a0dbcf857d07a6ebc1dff64 Mon Sep 17 00:00:00 2001
From: Luc Schrijvers <begasus@gmail.com>
Date: Mon, 4 May 2026 19:46:30 +0200
Subject: Fix installation path for $libDir/cmake


diff --git a/cmake/package/CMakeLists.txt b/cmake/package/CMakeLists.txt
index e53d889..ff8b3bf 100644
--- a/cmake/package/CMakeLists.txt
+++ b/cmake/package/CMakeLists.txt
@@ -1,6 +1,6 @@
 install(
   EXPORT claw
-  DESTINATION lib/cmake/claw/
+  DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/claw/
   FILE claw-config-generated.cmake
   )
 
@@ -19,7 +19,7 @@ install(
   FILES
     ${CMAKE_CURRENT_BINARY_DIR}/claw-config.cmake
     ${CMAKE_CURRENT_BINARY_DIR}/claw-config-version.cmake
-  DESTINATION lib/cmake/claw/
+  DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/claw/
   )
 
 
-- 
2.52.0


From 849c91147ef628c71792a034af9aa7268f7c53c0 Mon Sep 17 00:00:00 2001
From: Luc Schrijvers <begasus@gmail.com>
Date: Mon, 4 May 2026 19:58:46 +0200
Subject: Fix path for documentation


diff --git a/cmake/CMakeLists.txt b/cmake/CMakeLists.txt
index 47ec6e4..2220afc 100644
--- a/cmake/CMakeLists.txt
+++ b/cmake/CMakeLists.txt
@@ -9,7 +9,7 @@ include(GNUInstallDirs)
 set(repository_root "${CMAKE_CURRENT_LIST_DIR}/..")
 set(
   claw_install_documentation_dir
-  ${CMAKE_INSTALL_DATADIR}/doc/libclaw${CMAKE_PROJECT_VERSION_MAJOR}
+  ${CMAKE_INSTALL_PREFIX}/documentation/packages/libclaw${CMAKE_PROJECT_VERSION_MAJOR}
   )
 
 if(CMAKE_COMPILER_IS_GNUCXX)
-- 
2.52.0


From 25644ad2a086a1b40e4b7e235debd4e4880a7165 Mon Sep 17 00:00:00 2001
From: Jerome Duval <jerome.duval@gmail.com>
Date: Fri, 14 Sep 2018 09:17:54 +0200
Subject: Link claw_net against libnetwork.so


diff --git a/cmake/lib/net/CMakeLists.txt b/cmake/lib/net/CMakeLists.txt
index bc18fae..573b0ce 100644
--- a/cmake/lib/net/CMakeLists.txt
+++ b/cmake/lib/net/CMakeLists.txt
@@ -13,3 +13,7 @@ claw_library(
 if(WIN32)
   target_link_libraries(claw_net wsock32)
 endif()
+
+if(HAIKU)
+  target_link_libraries(claw_net PRIVATE network)
+endif(HAIKU)
-- 
2.52.0

