From b93792974143fdb347c2264ab16bf36fa427a532 Mon Sep 17 00:00:00 2001
From: Geoffrey Teale <geoffrey@teale.de>
Date: Mon, 6 Apr 2026 06:56:16 +0000
Subject: [PATCH 00/18] *** SUBJECT HERE ***

*** BLURB HERE ***

Geoffrey Teale (18):
  Separate Haiku build from FreeBSD
  Refine the haiku version.h further
  Disable xlocale.h for haiku
  Add a6hk and ta6hk machine types for Haiku
  Haiku has no -ldl and no -lrt
  Use libroot.so instead of libc.so on Haiku
  Add haiku? function to mat.ss, as per windows? function.
  Switch off unix.ms tests that fail because of Haiku differences.
  Fix unbalanced parenthesis in unix.ms
  Make haiku? more inline with windows?
  Guard out a weird test failure for getenv on haiku.
  Guard around tests that aren't valid for Haiku
  Guard around tests that aren't valid for Haiku
  Furher guards around tests that aren't valid for Haiku
  Use or instead of unless to ensure booleans for assertions
  Another attempt to surpress these test errors
  Patch out some time tests
  Tests all passing

 c/expeditor.c         |  2 +-
 c/version.h           | 32 +++++++++++++++++++++++++++++++-
 configure             | 15 ++++++++++-----
 makefiles/install.zuo | 15 ++++++++++-----
 mats/6.ms             | 16 ++++++++++++----
 mats/bytevector.ms    |  2 +-
 mats/date.ms          |  8 ++++----
 mats/foreign.ms       | 10 ++++++++++
 mats/io.ms            | 21 +++++++++++++++------
 mats/mat.ss           |  5 +++++
 mats/misc.ms          |  4 +++-
 mats/primvars.ms      |  2 +-
 mats/unix.ms          |  4 ++--
 s/cmacros.ss          |  1 +
 14 files changed, 106 insertions(+), 31 deletions(-)

-- 
2.52.0

From 11da7fe64a32149464e0198d50863346ead468eb Mon Sep 17 00:00:00 2001
From: Geoffrey Teale <geoffrey@teale.de>
Date: Tue, 31 Mar 2026 01:50:27 +0200
Subject: [PATCH 01/18] Separate Haiku build from FreeBSD

---
 c/version.h | 32 +++++++++++++++++++++++++++++++-
 1 file changed, 31 insertions(+), 1 deletion(-)

diff --git a/c/version.h b/c/version.h
index 9141e99..223b2fe 100644
--- a/c/version.h
+++ b/c/version.h
@@ -141,7 +141,37 @@ typedef int tputsputcchar;
 #endif
 #endif
 
-#if defined(__FreeBSD__) || defined(__FreeBSD_kernel__) || defined(__DragonFly__)
+#if  defined(__HAIKU__)
+#define NOBLOCK O_NONBLOCK
+#define LOAD_SHARED_OBJECT
+#define USE_MMAP
+#define MMAP_HEAP
+#define IEEE_DOUBLE
+#define LDEXP
+#define ARCHYPERBOLIC
+#define GETPAGESIZE() getpagesize()
+typedef char *memcpy_t;
+#define MAKE_NAN(x) { x = 0.0; x = x / x; }
+#define GETWD(x) getcwd((x),PATH_MAX)
+typedef int tputsputcchar;
+#define LOCKF
+#define DIRMARKERP(c) ((c) == '/')
+#ifndef DISABLE_X11
+#define LIBX11 "libX11.so"
+#endif
+#define SECATIME(sb) (sb).st_atime.tv_sec
+#define SECCTIME(sb) (sb).st_ctimespec.tv_sec
+#define SECMTIME(sb) (sb).st_mtimespec.tv_sec
+#define NSECATIME(sb) (sb).st_atime.tv_nsec
+#define NSECCTIME(sb) (sb).st_ctimespec.tv_nsec
+#define NSECMTIME(sb) (sb).st_mtimespec.tv_nsec
+#define ICONV_INBUF_TYPE char **
+#define USE_OSSP_UUID
+#endif
+
+
+
+#if defined(__FreeBSD__) || defined(__FreeBSD_kernel__) || defined(__DragonFly__) 
 #define NOBLOCK O_NONBLOCK
 #define LOAD_SHARED_OBJECT
 #define USE_MMAP
-- 
2.52.0


From 73eadcbf4cd2bcc83d0f8b86f39d0122aaa00cd7 Mon Sep 17 00:00:00 2001
From: Geoffrey Teale <geoffrey@teale.de>
Date: Tue, 31 Mar 2026 01:56:14 +0200
Subject: [PATCH 02/18] Refine the haiku version.h further

---
 c/version.h | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/c/version.h b/c/version.h
index 223b2fe..f8ae4cc 100644
--- a/c/version.h
+++ b/c/version.h
@@ -159,12 +159,12 @@ typedef int tputsputcchar;
 #ifndef DISABLE_X11
 #define LIBX11 "libX11.so"
 #endif
-#define SECATIME(sb) (sb).st_atime.tv_sec
-#define SECCTIME(sb) (sb).st_ctimespec.tv_sec
-#define SECMTIME(sb) (sb).st_mtimespec.tv_sec
-#define NSECATIME(sb) (sb).st_atime.tv_nsec
-#define NSECCTIME(sb) (sb).st_ctimespec.tv_nsec
-#define NSECMTIME(sb) (sb).st_mtimespec.tv_nsec
+#define SECATIME(sb) (sb).st_atime
+#define SECCTIME(sb) (sb).st_ctime
+#define SECMTIME(sb) (sb).st_mtime
+#define NSECATIME(sb) 0
+#define NSECCTIME(sb) 0
+#define NSECMTIME(sb) 0
 #define ICONV_INBUF_TYPE char **
 #define USE_OSSP_UUID
 #endif
-- 
2.52.0


From e3ea73e875f25f46540b0dd070d0bdc3bd7aee5a Mon Sep 17 00:00:00 2001
From: Geoffrey Teale <geoffrey@teale.de>
Date: Tue, 31 Mar 2026 16:43:09 +0200
Subject: [PATCH 03/18] Disable xlocale.h for haiku

