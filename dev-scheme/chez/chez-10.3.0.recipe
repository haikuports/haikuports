SUMMARY="Cisco's Chez Scheme compiler and interpreter"
DESCRIPTION="Both a programming language and an implementation of that language, with supporting tools and documentation.

As a superset of the language described in the Revised6 Report on the Algorithmic Language Scheme (R6RS), Chez Scheme supports all standard features of Scheme, including first-class procedures, proper treatment of tail calls, continuations, user-defined records, libraries, exceptions, and hygienic macro expansion.

Chez Scheme also includes extensive support for interfacing with C and other languages, support for multiple threads possibly running on multiple cores, non-blocking I/O, and many other features."
HOMEPAGE="https://cisco.github.io/ChezScheme/"
COPYRIGHT="2022 Cisco Systems, Inc."
LICENSE="Apache v2"
REVISION="1"
SOURCE_URI="https://github.com/cisco/ChezScheme/releases/download/v10.3.0/csv$portVersion.tar.gz"
SOURCE_DIR="csv$portVersion"
CHECKSUM_SHA256="d237d9874c6e8b0ccf7758daa8286a6e825528b13ce3b2bca56eb1f73cddbc2c"
PATCHES="chez-$portVersion.patchset"

ARCHITECTURES="x86_64"

PROVIDES="
	chez = $portVersion
	cmd:petite = $portVersion
	cmd:scheme = $portVersion
	cmd:scheme_script = $portVersion
	"
REQUIRES="
	haiku
	xlibe
	ncurses6
	libiconv
	"


BUILD_REQUIRES="
	haiku_devel
	devel:libiconv
	devel:libncurses
	devel:libx11
	"
BUILD_PREREQUIRES="
	cmd:gcc
	cmd:make
	cmd:ld
	cmd:diff
	cmd:patch
	cmd:git
	"

BUILD()
{
	./configure --pb
	make bootquick XM=ta6hk $jobArgs
	CPPFLAGS="-D_BSD_SOURCE" LIBS="-lbsd -lnetwork -lroot" \
	./configure --machine=ta6hk --threads --64 --prefix=$prefix --installbin=$binDir --installlib=$libDir --installman=$manDir --installdoc=$docDir --installabsolute
	make $jobArgs
}

INSTALL()
{
	make install
}

TEST()
{
	make test $jobArgs
}
