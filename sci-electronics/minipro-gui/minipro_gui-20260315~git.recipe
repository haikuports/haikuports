SUMMARY="Twelve-chairs - GUI wrapper for minipro CLI"
DESCRIPTION="GUI wrapper for the minipro CLI tool - a free and open TL866 series programmer"

HOMEPAGE="https://github.com/twelve-chairs/minipro-gui"
COPYRIGHT="2026 twelve-chairs contributors"
LICENSE="Public Domain"
REVISION="1"
srcGitRev="301934bc5eee600c71ef29f02e36826d7f035066"
SOURCE_URI="https://github.com/twelve-chairs/minipro-gui/archive/$srcGitRev.zip"
CHECKSUM_SHA256="26d476d951accba19b186b7c164372ce4961e6c95f7580ba7e032d2f6c1bd7d2"
SOURCE_DIR="minipro-gui-$srcGitRev"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	minipro_gui$secondaryArchSuffix = $portVersion
	app:minipro_gui$secondaryArchSuffix
	"

REQUIRES="
	haiku$secondaryArchSuffix
	lib:libfontconfig$secondaryArchSuffix
	lib:libQt6Core$secondaryArchSuffix
	lib:libGL$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libQt6Core$secondaryArchSuffix
	"

BUILD_PREREQUIRES="
	cmd:cmake
	cmd:gcc$secondaryArchSuffix
	cmd:ninja$secondaryArchSuffix
	"

BUILD()
{
	cmake -DCMAKE_BUILD_TYPE=MinSizeRel -DCMAKE_MAKE_PROGRAM=ninja -G Ninja -S . -B "./cmake-build-minsizerel"
	cmake --build ./cmake-build-minsizerel --target minipro-gui
}

INSTALL()
{
	mkdir -p $appsDir
	cp cmake-build-minsizerel/minipro-gui $appsDir/minipro-gui

	addAppDeskbarSymlink $appsDir/minipro-gui
}
