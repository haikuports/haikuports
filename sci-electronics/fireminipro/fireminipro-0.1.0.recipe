SUMMARY="Jartza - GUI for Minipro CLI"
DESCRIPTION="FireMinipro is a modern, cross-platform graphical \
front-end for the Minipro programmer software.
It is designed to be fast, intuitive, and lightweight — with special \
emphasis on buffer management and visual clarity.
"

HOMEPAGE="https://github.com/Jartza/fireminipro"
COPYRIGHT="2025 Jartza contributors"
LICENSE="MIT"
REVISION="1"
SOURCE_URI="https://github.com/Jartza/fireminipro/archive/refs/tags/v$portVersion.zip"
CHECKSUM_SHA256="7f9451eedd1733e1f7901f36cdba811f3f801eff50a4d68718e48398e08153fd"
SOURCE_DIR="fireminipro-$portVersion"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	fireminipro$secondaryArchSuffix = $portVersion
	app:fireminipro$secondaryArchSuffix
	"

REQUIRES="
	haiku$secondaryArchSuffix
	lib:libfontconfig$secondaryArchSuffix
	lib:libQt6Core$secondaryArchSuffix
	lib:libGL$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libQt6Core$secondaryArchSuffix
	"

BUILD_PREREQUIRES="
	cmd:cmake
	cmd:gcc$secondaryArchSuffix
	cmd:ninja$secondaryArchSuffix
	"

BUILD()
{
	mkdir -p build
	cd build
	cmake -G Ninja .. -DCMAKE_BUILD_TYPE=Release
	ninja
}

INSTALL()
{
	mkdir -p $appsDir
	cp build/fireminipro $appsDir/fireminipro

	addAppDeskbarSymlink $appsDir/fireminipro
}
