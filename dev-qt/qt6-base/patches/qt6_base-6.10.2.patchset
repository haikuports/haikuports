@@ -50,6 +50,12 @@ macro(qt_internal_setup_platform_definitions_and_mkspec)
         elseif(CLANG)
             set(QT_DEFAULT_MKSPEC linux-clang)
         endif()
+    elseif(HAIKU)
+        if(GCC)
+            set(QT_DEFAULT_MKSPEC haiku-g++)
+        elseif(CLANG)
+            set(QT_DEFAULT_MKSPEC haiku-clang)
+        endif()
     elseif(ANDROID)
         if(GCC)
             set(QT_DEFAULT_MKSPEC android-g++)
