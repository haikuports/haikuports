diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index d98a7f7..eeb04eb 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -385,9 +385,9 @@ if(APPLE)
     endif()
 endif()
 if(HAIKU)
-    target_link_libraries(keepassx_core Qt5::DBus be network)
+    target_link_libraries(keepassx_core be network)
 endif()
-if(UNIX AND NOT APPLE AND NOT HAIKU)
+if(UNIX AND NOT APPLE)
     target_link_libraries(keepassx_core Qt5::DBus ${LIBUSB_LIBRARIES})
     if(WITH_XC_X11)
         target_link_libraries(keepassx_core Qt5::X11Extras X11)
diff --git a/src/gui/MainWindow.cpp b/src/gui/MainWindow.cpp
index f26461a..cc10031 100644
--- a/src/gui/MainWindow.cpp
+++ b/src/gui/MainWindow.cpp
@@ -72,7 +72,7 @@
 #include "browser/BrowserService.h"
 #endif
 
-#if defined(Q_OS_UNIX) && !defined(Q_OS_MACOS) && !defined(QT_NO_DBUS)
+#if defined(Q_OS_UNIX) && !defined(Q_OS_MACOS) && !defined(Q_OS_HAIKU) && !defined(QT_NO_DBUS)
 #include "mainwindowadaptor.h"
 #endif
 
@@ -95,7 +95,7 @@ MainWindow::MainWindow()
     macUtils()->configureWindowAndHelpMenus(this, m_ui->menuHelp);
 #endif
 
-#if defined(Q_OS_UNIX) && !defined(Q_OS_MACOS) && !defined(QT_NO_DBUS)
+#if defined(Q_OS_UNIX) && !defined(Q_OS_MACOS) && !defined(Q_OS_HAIKU) && !defined(QT_NO_DBUS)
     new MainWindowAdaptor(this);
     QDBusConnection dbus = QDBusConnection::sessionBus();
     dbus.registerObject("/keepassxc", this);
diff --git a/src/gui/osutils/nixutils/NixUtils.cpp b/src/gui/osutils/nixutils/NixUtils.cpp
index 94ce685..503d3b2 100644
--- a/src/gui/osutils/nixutils/NixUtils.cpp
+++ b/src/gui/osutils/nixutils/NixUtils.cpp
