From ec5214d101dbef91ecd9d3b27598cb008f3bfdbe Mon Sep 17 00:00:00 2001
From: Luc Schrijvers <begasus@gmail.com>
Date: Sat, 4 Apr 2026 13:05:40 +0200
Subject: use Haiku's fallback icon theme


diff --git a/src/gui/Icons.cpp b/src/gui/Icons.cpp
index 0ada4a1..6187cc8 100644
--- a/src/gui/Icons.cpp
+++ b/src/gui/Icons.cpp
@@ -186,11 +186,16 @@ QIcon Icons::icon(const QString& name, bool recolor, const QColor& overrideColor
         return icon;
     }
 
+#ifdef Q_OS_HAIKU
+    QIcon::setFallbackThemeName("haiku");
+    icon = QIcon::fromTheme(name);
+#else
     icon = QIcon::fromTheme(name);
     if (recolor) {
         icon = QIcon(new AdaptiveIconEngine(icon, overrideColor));
         icon.setIsMask(true);
     }
+#endif
 
     m_iconCache.insert(cacheName, icon);
     return icon;
-- 
2.52.0

