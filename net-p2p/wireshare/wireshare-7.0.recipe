SUMMARY="Peer-to-peer sharing for Gnutella, BitTorrent, magnet, and eD2k"
DESCRIPTION="WireShare is a desktop peer-to-peer client for Gnutella, BitTorrent, magnet, \
and eD2k links. It lets you open and manage peer-to-peer downloads from a single \
desktop application. The Haiku package runs the WireShare Java application through \
the system Java runtime."
HOMEPAGE="https://github.com/nmatavka/hermes-wireshare"
COPYRIGHT="2026 Hermes"
LICENSE="GPL v3"
REVISION="1"
SOURCE_URI="https://github.com/nmatavka/hermes-wireshare/releases/download/release/7.0/WireShare.jar#noarchive"
CHECKSUM_SHA256="09926966fcaa38697e7b9333316a6e65d128c56add156df3da4f042885fb1c05"
SOURCE_FILENAME="WireShare.jar"

ARCHITECTURES="any"
DISABLE_SOURCE_PACKAGE="yes"

PROVIDES="
	wireshare = $portVersion
	cmd:WireShare = $portVersion
	"
REQUIRES="
	haiku
	java:environment >= 21
	cmd:java
	"

INSTALL()
{
	mkdir -p $binDir $dataDir/wireshare
	cp $sourceDir/WireShare.jar $dataDir/wireshare/WireShare-7.0.jar

	cat > $binDir/WireShare <<EOF
#!/bin/sh
exec java -jar $dataDir/wireshare/WireShare.jar "\$@"
EOF
	chmod +x $binDir/WireShare
}
