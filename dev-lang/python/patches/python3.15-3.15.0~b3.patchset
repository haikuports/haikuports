From e3cf6e8ff9c44acc953b0004e4940aacd55c8c0f Mon Sep 17 00:00:00 2001
From: Oscar Lesta <oscar.lesta@gmail.com>
Date: Wed, 22 Apr 2026 05:00:21 -0300
Subject: Increase thread stack size (see #14016).


diff --git a/Python/thread_pthread.h b/Python/thread_pthread.h
index 8496f91..0044369 100644
--- a/Python/thread_pthread.h
+++ b/Python/thread_pthread.h
@@ -52,7 +52,7 @@
  * as it also depends on the other configure options like chosen sanitizer
  * runtimes.
  */
-#if defined(__FreeBSD__) && defined(THREAD_STACK_SIZE) && THREAD_STACK_SIZE == 0
+#if (defined(__FreeBSD__) || defined(__HAIKU__)) && defined(THREAD_STACK_SIZE) && THREAD_STACK_SIZE == 0
 #undef  THREAD_STACK_SIZE
 #define THREAD_STACK_SIZE       0x400000
 #endif
