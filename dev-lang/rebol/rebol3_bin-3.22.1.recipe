SUMMARY="A lightweight scripting language"
DESCRIPTION="A scripting language that provides a lightweight platform for distributed \
computing and communication. It is mainly designed for network communications, \
providing effective solutions to modern network distributed applications."
HOMEPAGE="http://www.rebol.com/
	https://github.com/Oldes/Rebol3"
COPYRIGHT="2012 REBOL Technologies
	2012-2026 Rebol Open Source Contributors"
LICENSE="Apache v2"
REVISION="1"
if [ "$targetArchitecture" = x86_gcc2 ]; then
SOURCE_URI="https://github.com/Oldes/Rebol3/releases/download/3.22.1/rebol3-bulk-haiku-x86.gz#noarchive"
CHECKSUM_SHA256="083cc62e475a8d943a28635404dc24dcb4d43807480d057b5365de2d07294386"
elif [ "$targetArchitecture" = x86_64 ]; then
SOURCE_URI="https://github.com/Oldes/Rebol3/releases/download/3.22.1/rebol3-bulk-haiku-x64.gz#noarchive"
CHECKSUM_SHA256="302969f13d7b2663cd059720d12c394cf898a4e3b7eafa3869017efbd55f0393"
fi
SOURCE_DIR=""
SOURCE_FILENAME="rebol3-$portVersion.gz"

ARCHITECTURES="!all x86_gcc2 x86_64"

PROVIDES="
	rebol3_bin = $portVersion
	cmd:rebol3 = $portVersion
	"
REQUIRES="
	haiku
	lib:libiconv
	"

BUILD_REQUIRES="
	haiku_devel
	"
BUILD_PREREQUIRES="
	cmd:gunzip
	"

INSTALL()
{
	mkdir -p $prefix/bin
	gunzip -c --keep $sourceDir/rebol3-$portVersion.gz > $prefix/bin/rebol3
	chmod +x $prefix/bin/rebol3
}
