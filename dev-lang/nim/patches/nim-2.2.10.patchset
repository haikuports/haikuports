+++ b/dist/nimble/vendor/chronos/chronos/config.nim
@@ -78,7 +78,7 @@ const
       "epoll"
     elif defined(macosx) or defined(macos) or defined(ios) or
           defined(freebsd) or defined(netbsd) or defined(openbsd) or
