SUMMARY="A simple synced-lyrics music player"
DESCRIPTION="Cantus is a simple audio player for Haiku. \
It automatically reads .lrc files located alongside your audio files and \
 synchronizes them with the playback."
HOMEPAGE="https://codeberg.org/ebruce/cantus"
COPYRIGHT="2026 ebruce"
LICENSE="MIT"
REVISION="1"

SOURCE_URI="https://codeberg.org/ebruce/cantus/archive/$portVersion.tar.gz"
CHECKSUM_SHA256="190524cb007c77f1b18a55b44c1ac9c11b9d2290c4ee2bcfeeb14bb9ccb1640b"
SOURCE_DIR="cantus"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	cantus$secondaryArchSuffix = $portVersion
	app:Cantus = $portVersion
	"
REQUIRES="
	haiku$secondaryArchSuffix
	"
BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	"
BUILD_PREREQUIRES="
	makefile_engine
	cmd:gcc$secondaryArchSuffix
	cmd:make
	"

BUILD()
{
	make $jobArgs
}

INSTALL()
{
	mkdir -p $appsDir
	cp objects.*/Cantus $appsDir/Cantus

	addAppDeskbarSymlink $appsDir/Cantus
}
