SUMMARY="A command-line controller for Haiku Work Spaces"
DESCRIPTION="workspacesctl is most useful in combination with Haiku's \
Shortcuts. The two together can provide full keyboard navigation of a large \
grid of Workspaces."
HOMEPAGE="https://forge.full0fstars.net/Public/workspacesctl"
COPYRIGHT="us3r1d, 2026"
LICENSE="CC-BY-NC-SA-4.0"
REVISION="1"
SOURCE_URI="https://forge.full0fstars.net/Public/workspacesctl/archive/workspacesctl-$portVersion.tar.gz"
SOURCE_FILENAME="workspacesctl-$portVersion.tar.gz"
SOURCE_DIR="workspacesctl"
CHECKSUM_SHA256="1aecd277b3dc773ce0a0cc8f8532b7944a3eda0097978ce5be46a3448c11fe6c"

ARCHITECTURES="all"

PROVIDES="
	workspacesctl = $portVersion
	cmd:workspacesctl = $portVersion
	"
REQUIRES="
	haiku
	"

BUILD_REQUIRES="
	haiku_devel
	make
	"
BUILD_PREREQUIRES="
	makefile_engine
	cmd:g++
	cmd:make
	"

BUILD()
{
	make
}

INSTALL()
{
	mkdir -p $binDir
	cp -p workspacesctl $binDir/
 	mkdir -p $documentationDir/packages/workspacesctl
 	cp -p README.md  $documentationDir/packages/workspacesctl/
 	cp -p shortcuts.png  $documentationDir/packages/workspacesctl/
 	cp -p shortcuts.keyset $documentationDir/packages/workspacesctl/
}
