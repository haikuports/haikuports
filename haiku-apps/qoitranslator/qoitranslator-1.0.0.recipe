SUMMARY="QOI Translator for Haiku"
DESCRIPTION="A Haiku Translation Kit add-on providing support for the QOI \
(Quite OK Image) format.

QOI is a fast, lossless image format designed as a simple and efficient \
alternative to PNG, with a focus on straightforward implementation and \
high decoding speed.

The format was created by Dominic Szablewski (phoboslab) and is based on a \
compact, lossless compression scheme without complex metadata. \
More information is available at https://qoiformat.org/

Installing this add-on enables any application using the Haiku Translation \
Kit to read and write QOI image files."
HOMEPAGE="https://github.com/dospuntos/QOITranslator"
COPYRIGHT="2026 Johan Wagenheim"
LICENSE="MIT"
REVISION="1"
SOURCE_URI="https://github.com/dospuntos/QOITranslator/archive/refs/tags/v$portVersion.tar.gz"
CHECKSUM_SHA256="4a2070f51618601f40f4c807c26f9da65ef50e6afd31f902246415a3bd0fa339"
SOURCE_DIR="QOITranslator-$portVersion"

ARCHITECTURES="all"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	qoitranslator$secondaryArchSuffix = $portVersion
	addon:QOITranslator = $portVersion
	"
REQUIRES="
	haiku$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	"
BUILD_PREREQUIRES="
	makefile_engine
	cmd:gcc$secondaryArchSuffix
	cmd:make
	"

BUILD()
{
	make $jobArgs
	rc QOIMime.rdef -o QOIMime.rsrc
}

INSTALL()
{
	mkdir -p $addOnsDir/Translators
	cp objects.*-release/QOITranslator $addOnsDir/Translators/QOITranslator

	# Install MIME registration resources
	mkdir -p $dataDir/mime_db/image
	resattr -O -o $dataDir/mime_db/image/x-qoi QOIMime.rsrc
}