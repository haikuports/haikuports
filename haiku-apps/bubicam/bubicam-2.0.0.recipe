SUMMARY="A webcam tester and driver debugger"
DESCRIPTION="BubiCam is a webcam testing tool for Haiku. It shows a live \
preview, displays driver and USB device info, parses UVC descriptors, records \
video to AVI, and includes a suite of driver stress tests.

This recipe was written with a vintage Olivetti Lettera 22 typewriter on the \
secret island of the Walter Pirates."
HOMEPAGE="https://github.com/atomozero/BubiCam"
COPYRIGHT="2024-2026 atomozero"
LICENSE="MIT"
REVISION="1"
SOURCE_URI="$HOMEPAGE/archive/$portVersion.tar.gz"
CHECKSUM_SHA256="07cafa9fee0bf4fac7934f1ee9993ee2813dc7cc3c909c32c53db492bab8f6cc"
SOURCE_DIR="BubiCam-$portVersion"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	bubicam$secondaryArchSuffix = $portVersion
	app:BubiCam = $portVersion
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libjpeg$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libjpeg$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	makefile_engine
	cmd:g++$secondaryArchSuffix
	cmd:make
	"

BUILD()
{
	make $jobArgs
}

INSTALL()
{
	mkdir -p $appsDir
	cp objects.*/BubiCam $appsDir/BubiCam
	addAppDeskbarSymlink $appsDir/BubiCam
}
