SUMMARY="A native VNC remote desktop client"
DESCRIPTION="This is a VNC client that was written specifically for Haiku. It is a lightweight, self-contained program like a traditional BeOS app, that is intended to give a better experience than clients ported from other platforms."
APP="vncclient"
HOMEPAGE=""
COPYRIGHT="Graham Willmott"
LICENSE="Zlib"
REVISION="1"
SOURCE_URI="http://cathoren.net/archive/vncclient-1.0.tgz"
CHECKSUM_SHA256="86b7a6003baa4cccb9a0cb24026024dd7d18434297e10fc099cd802bdd254240"
SOURCE_DIR="$APP"
ARCHITECTURES="x86_gcc2 x86 x86_64"
PROVIDES="
	$APP = $portVersion
	app:$APP = $portVersion
"
REQUIRES="
	haiku
	"
BUILD_REQUIRES="
	haiku_devel
	"
BUILD_PREREQUIRES="
	cmd:gcc
	cmd:g++
	cmd:ar
	cmd:make
	cmd:tar
	cmd:xres
	"
BUILD()
{
	make -j
}
INSTALL()
{
	install -m 0755 -d "$appsDir"
	install -m 0755 -t "$appsDir" vncclient
	addAppDeskbarSymlink $appsDir/vncclient "VNC Client"
}
